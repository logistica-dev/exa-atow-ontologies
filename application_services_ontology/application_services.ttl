@prefix : <http://www.semanticweb.org/grichet/ontologies/applicationServices/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/grichet/ontologies/applicationServices/> .

<http://www.semanticweb.org/grichet/ontologies/applicationServices> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/grichet/ontologies/applicationServices#executesTasksFrom
:executesTasksFrom rdf:type owl:ObjectProperty ;
                   owl:inverseOf :hostsTasksFor ;
                   rdfs:domain :runtime ;
                   rdfs:range :microservice ;
                   rdfs:comment "A Runtime fetches Jobs posted to a Microservice and executes the associated tasks."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices#fetches
:fetches rdf:type owl:ObjectProperty ;
         owl:inverseOf :isFetchedBy ;
         rdfs:domain :runtime ;
         rdfs:range :job ;
         rdfs:comment "A Runtime fetches Jobs posted to a Microservice and executes the associated tasks."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices#hosts
:hosts rdf:type owl:ObjectProperty ;
       owl:inverseOf :isPostedTo ;
       rdfs:domain :microservice ;
       rdfs:range :job ;
       rdfs:comment "A Runtime fetches Jobs posted to a Microservice and executes the associated tasks."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices#hostsTasksFor
:hostsTasksFor rdf:type owl:ObjectProperty ;
               rdfs:domain :microservice ;
               rdfs:range :runtime ;
               rdfs:comment "A Runtime fetches Jobs posted to a Microservice and executes the associated tasks."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices#isFetchedBy
:isFetchedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :job ;
             rdfs:range :runtime ;
             rdfs:comment "A Runtime fetches Jobs posted to a Microservice and executes the associated tasks."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices#isPostedTo
:isPostedTo rdf:type owl:ObjectProperty ;
            rdfs:domain :job ;
            rdfs:range :microservice ;
            rdfs:comment "A Runtime fetches Jobs posted to a Microservice and executes the associated tasks."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/declares
:declares rdf:type owl:ObjectProperty ;
          owl:inverseOf :isDeclaredBy ;
          rdfs:domain :role ;
          rdfs:range :applicationServicesElement ;
          rdfs:comment """The maintainer is the one declaring Runtimes.
The developer is the one declaring Microservices.
The scientist is the one posting Jobs."""@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/hasMimeType
:hasMimeType rdf:type owl:ObjectProperty ;
             rdfs:domain :microservice ;
             rdfs:range :mimeType ;
             rdfs:comment "A Microservice has a given MIME type, linking it to a Runtime."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/hasRole
:hasRole rdf:type owl:ObjectProperty ;
         owl:inverseOf :isRoleOf ;
         rdfs:domain :federationUser ;
         rdfs:range :role ;
         rdfs:comment "A Federation user can be a scientist, a developer or an application maintainer."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/hasRule
:hasRule rdf:type owl:ObjectProperty ;
         owl:inverseOf :isRuleFor ;
         rdfs:domain :applicationServicesElement ;
         rdfs:range :policy ;
         rdfs:comment """If needed, the scientific developer or the application maintainer can independently add a policy descriptor fixing the limits in access or usage of their service.

For instance, the developer can restrict the access of some features to a subset
of the federation.
The application maintainer might also want to introduce on
their side some fair usage rules like a limited number of jobs per user and per unit
of time."""@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/isDeclaredBy
:isDeclaredBy rdf:type owl:ObjectProperty ;
              rdfs:domain :applicationServicesElement ;
              rdfs:range :role ;
              rdfs:comment """The maintainer is the one declaring Runtimes.
The developer is the one declaring Microservices.
The scientist is the one posting Jobs."""@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/isRoleOf
:isRoleOf rdf:type owl:ObjectProperty ;
          rdfs:domain :role ;
          rdfs:range :federationUser ;
          rdfs:comment "A Federation user can be a scientist, a developer or an application maintainer."@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/isRuleFor
:isRuleFor rdf:type owl:ObjectProperty ;
           rdfs:domain :policy ;
           rdfs:range :applicationServicesElement ;
           rdfs:comment """If needed, the scientific developer or the application maintainer can independently add a policy descriptor fixing the limits in access or usage of their service.

For instance, the developer can restrict the access of some features to a subset
of the federation.
The application maintainer might also want to introduce on
their side some fair usage rules like a limited number of jobs per user and per unit
of time."""@en .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/grichet/ontologies/applicationServices/mimeTypeValue
:mimeTypeValue rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :mimeType ;
               rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/grichet/ontologies/applicationServices/applicationServicesElement
:applicationServicesElement rdf:type owl:Class .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/developer
:developer rdf:type owl:Class ;
           rdfs:subClassOf :role ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :declares ;
                             owl:allValuesFrom :microservice
                           ] ;
           rdfs:comment "Le développeur est celui qui déclare un Micro-service et qui développe l'application correspondante."@fr ,
                        "The developer is the one declaring a Microservice and developing the corresponding application."@en ;
           rdfs:label "developer"@en ,
                      "développeur"@fr .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/eBuffer
:eBuffer rdf:type owl:Class .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/federationUser
:federationUser rdf:type owl:Class ;
                rdfs:comment "A Federation User is a user identified within the federation. They have access to at least one of the element of the continuum."@en ,
                             "Un utilisateur est identifié dans la fédération. Il a accès à au moins l'un des éléments du continuum."@fr ;
                rdfs:label "federation user"@en ,
                           "utilisateur dans la fédération"@fr .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/job
:job rdf:type owl:Class ;
     rdfs:subClassOf :applicationServicesElement ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :isDeclaredBy ;
                       owl:allValuesFrom :scientist
                     ] ;
     rdfs:comment """A Job is posted to a Microservice by a scientist. It is then fetched by a Runtime, and the associated task is executed on the compute center.

A Job is defined by a unique identifier (UUID), a Microservice UUID,
and a set of input/output values or Ephemeral Buffer UUIDs corresponding
to the Microservice signature."""@en ,
                  """Un Job est soumis à un Micro-service par un scientifique. Il est ensuite récupéré par un Runtime et la tâche associée est exécutée dans un centre de calcul.

Un Job est défini par un identifiant unique (UUID), l'UUID d'un Micro-service, et un ensemble de valeurs d'input/output ou d'UUIDs de Buffers Éphémères correspondant à la signature du Micro-service."""@fr ;
     rdfs:label "job"@en ,
                "job"@fr .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/maintainer
:maintainer rdf:type owl:Class ;
            rdfs:subClassOf :role ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :declares ;
                              owl:allValuesFrom :runtime
                            ] ;
            rdfs:comment "Le maintainer déclare un ou des Runtimes. Il est celui qui contrôle l'exécution effective d'une tâche sur un centre de calcul."@fr ,
                         "The maintainer declares one or several Runtimes. They are the one handling the actual execution of a task on a compute center."@en ;
            rdfs:label "maintainer"@en ,
                       "maintainer"@fr .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/microservice
:microservice rdf:type owl:Class ;
              rdfs:subClassOf :applicationServicesElement ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :isDeclaredBy ;
                                owl:allValuesFrom :developer
                              ] ;
              rdfs:comment """A Microservice is an interface contract for Jobs.

A Microservice is defined by a unique identifier (UUID), a signature, a code bootstrap, either an application type or by an explicit Runtime UID, and a policy UUID."""@en ,
                           """Un Micro-service est un contrat d'interface pour des jobs.

Un Micro-service est défini par un identifiant unique (UUID), une signature (ou contrat d'interface), un bootstrap de code, un type d'application (MIME type) ou l'UUID explicite d'un Runtime, et l'UUID d'un ensemble de règles."""@fr ;
              rdfs:label "micro-service"@fr ,
                         "microservice"@en .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/mimeType
:mimeType rdf:type owl:Class ;
          rdfs:comment "Le type MIME d'une application permet au maintainer et au développeur de relier des runtimes avec des micro-services"@fr ,
                       "The application MIME type allows maintainers and developers to link runtimes and microservices"@en ;
          rdfs:label "MIME type"@en ,
                     "type MIME"@fr .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/policy
:policy rdf:type owl:Class ;
        rdfs:comment """Le développeur et le maintainer peuvent indépendamment ajouter une description des règles limitant les façons d'utiliser et d'accéder à leurs services.
Par exemple, le développeur peut restreindre l'accès à certaines fonctionalités à un sous-ensemble précis de la fédération.
Le maintainer pourrait aussi vouloir introduire des règles d'utilisation équitable, limitant le nombre de jobs par utilisateur et par unité de temps."""@fr ,
                     """The scientific developer or the application maintainer can independently add a policy descriptor fixing the limits in access or usage of their services.
For instance, the developer can restrict the access of some features to a subset
of the federation.
The application maintainer might also want to introduce on
their side some fair usage rules like a limited number of jobs per user and per unit
of time."""@en ;
        rdfs:label "policy"@en ,
                   "politique"@fr .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/role
:role rdf:type owl:Class .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/runtime
:runtime rdf:type owl:Class ;
         rdfs:subClassOf :applicationServicesElement ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :isDeclaredBy ;
                           owl:allValuesFrom :maintainer
                         ] ;
         rdfs:comment """An application maintainer can declare a Runtime willing to execute tasks from a Microservice (identified by its MIME type), and installs the associated executing daemon inside the computer center.
When a Job is posted to a corresponding Microservice, it remains there until the Runtime's executing daemon fetches the job and executes the task in the compute center.

A Runtime is defined by a unique identifier (UUID), a name, an application type (MIME type), and a policy UUID."""@en ,
                      """Un maintainer peut déclarer un Runtime permettant d'exécuter les tâches d'un Micro-service (identifié par son type MIME), et installe le daemon associé dans le centre de calcul.
Quand un Job est soumis au Micro-service correspondant, il y reste jusqu'à ce que le daemon du Runtime le récupère et exécute la tâche dans le centre de calcul.

Un Runtime est défini par un identifiant unique (UUID), un nom, un type d'application (type MIME) et l'UUID d'un ensemble de règles (policy)."""@fr ;
         rdfs:label "runtime"@en ,
                    "runtime"@fr .


###  http://www.semanticweb.org/grichet/ontologies/applicationServices/scientist
:scientist rdf:type owl:Class ;
           rdfs:subClassOf :role ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :declares ;
                             owl:allValuesFrom :job
                           ] ;
           rdfs:comment "Le scientifique est celui qui soumet des Jobs à des Micro-services."@fr ,
                        "The scientist is the one posting Jobs to Microservices."@en ;
           rdfs:label "scientifique"@fr ,
                      "scientist"@en .


