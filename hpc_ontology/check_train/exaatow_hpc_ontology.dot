digraph ExaATowHPCOntology {
    // Graph-level settings
    graph [
        rankdir=LR,
        fontname="Helvetica",
        fontsize=11,
        splines=ortho,
        nodesep=0.5,
        ranksep=1.2,
        label="Exa-AToW HPC Resource Ontology v0.3\nClass Hierarchy & Key Relations",
        labelloc=t,
        labeljust=c
    ];
    node [
        fontname="Helvetica",
        fontsize=10,
        shape=box,
        style="filled,rounded",
        margin="0.15,0.08"
    ];
    edge [
        fontname="Helvetica",
        fontsize=9
    ];

    // ===========================================================
    // NODE STYLES BY CATEGORY
    // ===========================================================

    // Top-level abstract root
    HPCResource         [label="HPCResource", fillcolor="#2C3E50", fontcolor=white, shape=box, style="filled"];

    // ── Physical Resources ──────────────────────────────────────
    PhysicalResource    [label="PhysicalResource", fillcolor="#1A5276", fontcolor=white];

    // Compute Nodes
    ComputeNode         [label="ComputeNode", fillcolor="#2874A6", fontcolor=white];
    ScalarNode          [label="ScalarNode\n(CPU only)", fillcolor="#5DADE2", fontcolor=white];
    AcceleratedNode     [label="AcceleratedNode\n(CPU + GPU)", fillcolor="#5DADE2", fontcolor=white];
    FrontendNode        [label="FrontendNode\n(login/submit)", fillcolor="#85C1E9", fontcolor="#1A2951"];
    PrePostNode         [label="PrePostNode\n(pre/post-processing)", fillcolor="#85C1E9", fontcolor="#1A2951"];
    VisualizationNode   [label="VisualizationNode", fillcolor="#85C1E9", fontcolor="#1A2951"];

    // Processors
    Processor           [label="Processor", fillcolor="#1E8449", fontcolor=white];
    CPU                 [label="CPU", fillcolor="#27AE60", fontcolor=white];
    GPU                 [label="GPU", fillcolor="#27AE60", fontcolor=white];
    Accelerator         [label="Accelerator", fillcolor="#52BE80", fontcolor="#1A2951"];
    AcceleratorCard     [label="AcceleratorCard\n(e.g. A100 SXM4 80GB)", fillcolor="#A9DFBF", fontcolor="#1A2951"];
    Core                [label="Core", fillcolor="#A9DFBF", fontcolor="#1A2951"];

    // Memory
    Memory              [label="Memory (volatile)", fillcolor="#6C3483", fontcolor=white];
    RAM                 [label="RAM (DRAM)", fillcolor="#8E44AD", fontcolor=white];
    HBMMemory           [label="HBM Memory\n(GPU on-package)", fillcolor="#A569BD", fontcolor=white];

    // Persistent Storage
    Storage             [label="Storage (persistent)", fillcolor="#784212", fontcolor=white];
    SSD                 [label="SSD", fillcolor="#A04000", fontcolor=white];
    HDD                 [label="HDD", fillcolor="#A04000", fontcolor=white];
    NVMe                [label="NVMe\n(local scratch)", fillcolor="#CA6F1E", fontcolor=white];

    // Infrastructure
    Rack                [label="Rack", fillcolor="#717D7E", fontcolor=white];
    Server              [label="Server", fillcolor="#717D7E", fontcolor=white];

    // Interconnect
    Interconnect        [label="Interconnect", fillcolor="#0E6251", fontcolor=white];
    IntelOmniPath       [label="Intel Omni-Path\n(OPA 100 Gb/s)", fillcolor="#148F77", fontcolor=white];
    InfiniBand          [label="InfiniBand", fillcolor="#148F77", fontcolor=white];
    InfiniBandHDR       [label="InfiniBand HDR\n(200 Gb/s)", fillcolor="#1ABC9C", fontcolor="#1A2951"];
    InfiniBandNDR       [label="InfiniBand NDR\n(400 Gb/s)", fillcolor="#1ABC9C", fontcolor="#1A2951"];
    SlingShot           [label="HPE Cray Slingshot\n(200 Gb/s)", fillcolor="#1ABC9C", fontcolor="#1A2951"];

    // ── Logical Resources ────────────────────────────────────────
    LogicalResource     [label="LogicalResource", fillcolor="#7E5109", fontcolor=white];
    Partition           [label="Partition\n(SLURM partition)", fillcolor="#B7950B", fontcolor=white];
    FileSystem          [label="FileSystem", fillcolor="#B7950B", fontcolor=white];
    ParallelFileSystem  [label="ParallelFileSystem", fillcolor="#D4AC0D", fontcolor="#1A2951"];
    Lustre              [label="Lustre", fillcolor="#F9E79F", fontcolor="#1A2951"];
    GPFS                [label="GPFS / Spectrum Scale", fillcolor="#F9E79F", fontcolor="#1A2951"];
    StorageMount        [label="StorageMount\n($HOME, $SCRATCH…)", fillcolor="#F0E68C", fontcolor="#1A2951"];
    QoS                 [label="QoS\n(SLURM quality of service)", fillcolor="#F0E68C", fontcolor="#1A2951"];

    // ── Partition Types ──────────────────────────────────────────
    PartitionType       [label="PartitionType", fillcolor="#922B21", fontcolor=white];
    ComputePartition    [label="ComputePartition", fillcolor="#C0392B", fontcolor=white];
    CPUPartition        [label="CPUPartition", fillcolor="#E74C3C", fontcolor=white];
    GPUPartition        [label="GPUPartition", fillcolor="#E74C3C", fontcolor=white];
    PrePostPartition    [label="PrePostPartition", fillcolor="#EC7063", fontcolor="#1A2951"];
    VisualizationPartition [label="VisualizationPartition", fillcolor="#EC7063", fontcolor="#1A2951"];
    CompilationPartition [label="CompilationPartition", fillcolor="#EC7063", fontcolor="#1A2951"];
    ArchivePartition    [label="ArchivePartition", fillcolor="#EC7063", fontcolor="#1A2951"];

    // ── System-level ─────────────────────────────────────────────
    System              [label="System", fillcolor="#1B2631", fontcolor=white];
    Supercomputer       [label="Supercomputer", fillcolor="#273746", fontcolor=white];
    HPCCenter           [label="HPCCenter\n(Jean Zay, TGCC, Adastra…)", fillcolor="#273746", fontcolor=white];
    HardwareGeneration  [label="HardwareGeneration\n(extension/phase)", fillcolor="#5D6D7E", fontcolor=white];

    // ── Infrastructure ───────────────────────────────────────────
    Infrastructure      [label="Infrastructure", fillcolor="#616A6B", fontcolor=white];
    CoolingSystem       [label="CoolingSystem", fillcolor="#839192", fontcolor=white];
    EnergyManagement    [label="EnergyManagement", fillcolor="#839192", fontcolor=white];

    // ── Software ─────────────────────────────────────────────────
    Software            [label="Software", fillcolor="#1A5276", fontcolor=white, shape=box, style="filled,dashed"];
    ResourceManager     [label="ResourceManager\n(SLURM, PBS, LSF)", fillcolor="#2471A3", fontcolor=white, style="filled,dashed"];
    Compiler            [label="Compiler\n(GCC, Intel, NVCC…)", fillcolor="#2471A3", fontcolor=white, style="filled,dashed"];
    OperatingSystem     [label="OperatingSystem", fillcolor="#2471A3", fontcolor=white, style="filled,dashed"];
    SoftwareVersion     [label="SoftwareVersion", fillcolor="#5499C7", fontcolor=white, style="filled,dashed"];
    ParallelLibrary     [label="ParallelLibrary\n(MPI, CUDA, OpenMP…)", fillcolor="#5499C7", fontcolor=white, style="filled,dashed"];
    ModuleEnvironment   [label="ModuleEnvironment\n(Lmod, Modules)", fillcolor="#5499C7", fontcolor=white, style="filled,dashed"];

    // ── Quantitative Values ───────────────────────────────────────
    QuantitativeValue   [label="QuantitativeValue\n(value + unit)", fillcolor="#4A235A", fontcolor=white];
    DieSize             [label="DieSize (mm²)", fillcolor="#7D3C98", fontcolor=white];
    Lifetime            [label="Lifetime", fillcolor="#7D3C98", fontcolor=white];
    MemoryCapacity      [label="MemoryCapacity (GB/TB)", fillcolor="#7D3C98", fontcolor=white];
    StorageCapacity     [label="StorageCapacity (PB/TB)", fillcolor="#7D3C98", fontcolor=white];
    Frequency           [label="Frequency (GHz)", fillcolor="#7D3C98", fontcolor=white];
    Bandwidth           [label="Bandwidth (Gb/s)", fillcolor="#7D3C98", fontcolor=white];
    Throughput          [label="Throughput (TB/s)", fillcolor="#7D3C98", fontcolor=white];
    PeakPerformance     [label="PeakPerformance\n(PFlop/s)", fillcolor="#7D3C98", fontcolor=white];
    PowerConsumption    [label="PowerConsumption (W/MW)", fillcolor="#7D3C98", fontcolor=white];
    TDP                 [label="TDP", fillcolor="#9B59B6", fontcolor=white];

    // ── Organization ─────────────────────────────────────────────
    Organization        [label="Organization\n(IDRIS, CEA, CNRS, GENCI…)", fillcolor="#186A3B", fontcolor=white];
    FundingAgency       [label="FundingAgency\n(GENCI, ANR, France 2030…)", fillcolor="#239B56", fontcolor=white];

    // ── Performance Metric ────────────────────────────────────────
    PerformanceMetric   [label="PerformanceMetric", fillcolor="#4A235A", fontcolor=white];


    // ===========================================================
    // LEGEND
    // ===========================================================
    subgraph cluster_legend {
        label="Legend";
        fontsize=10;
        style=dotted;
        L1 [label="subClassOf (hierarchy)", shape=plaintext, fillcolor=white, style=filled];
        L2 [label="objectProperty (relation)", shape=plaintext, fillcolor=white, style=filled];
        L3 [label="──▶  subClassOf", shape=plaintext, fillcolor=white, style=filled];
        L4 [label="- - ▶  objectProperty", shape=plaintext, fillcolor=white, style=filled];
    }


    // ===========================================================
    // SUBCLASSOF HIERARCHY  (solid arrows)
    // ===========================================================

    // Top-level
    HPCResource -> PhysicalResource  [arrowhead=empty];
    HPCResource -> LogicalResource   [arrowhead=empty];
    HPCResource -> System            [arrowhead=empty];
    HPCResource -> Infrastructure    [arrowhead=empty];

    // Physical → ComputeNode
    PhysicalResource -> ComputeNode    [arrowhead=empty];
    ComputeNode -> ScalarNode          [arrowhead=empty];
    ComputeNode -> AcceleratedNode     [arrowhead=empty];
    ComputeNode -> FrontendNode        [arrowhead=empty];
    ComputeNode -> PrePostNode         [arrowhead=empty];
    ComputeNode -> VisualizationNode   [arrowhead=empty];

    // Physical → Processor
    PhysicalResource -> Processor  [arrowhead=empty];
    Processor -> CPU               [arrowhead=empty];
    Processor -> Accelerator       [arrowhead=empty];
    Accelerator -> GPU             [arrowhead=empty];

    // Physical → AcceleratorCard, Core, Memory, Storage, Rack, Server, Interconnect
    PhysicalResource -> AcceleratorCard  [arrowhead=empty];
    PhysicalResource -> Core             [arrowhead=empty];
    PhysicalResource -> Memory           [arrowhead=empty];
    Memory -> RAM                        [arrowhead=empty];
    Memory -> HBMMemory                  [arrowhead=empty];
    PhysicalResource -> Storage          [arrowhead=empty];
    Storage -> SSD                       [arrowhead=empty];
    Storage -> HDD                       [arrowhead=empty];
    SSD -> NVMe                          [arrowhead=empty];
    PhysicalResource -> Rack             [arrowhead=empty];
    PhysicalResource -> Server           [arrowhead=empty];
    PhysicalResource -> Interconnect     [arrowhead=empty];
    Interconnect -> IntelOmniPath        [arrowhead=empty];
    Interconnect -> InfiniBand           [arrowhead=empty];
    InfiniBand -> InfiniBandHDR          [arrowhead=empty];
    InfiniBand -> InfiniBandNDR          [arrowhead=empty];
    Interconnect -> SlingShot            [arrowhead=empty];

    // Logical → Partition, FileSystem, StorageMount, QoS
    LogicalResource -> Partition         [arrowhead=empty];
    LogicalResource -> FileSystem        [arrowhead=empty];
    LogicalResource -> StorageMount      [arrowhead=empty];
    LogicalResource -> QoS               [arrowhead=empty];
    FileSystem -> ParallelFileSystem     [arrowhead=empty];
    ParallelFileSystem -> Lustre         [arrowhead=empty];
    ParallelFileSystem -> GPFS           [arrowhead=empty];

    // PartitionType hierarchy
    PartitionType -> ComputePartition    [arrowhead=empty];
    ComputePartition -> CPUPartition     [arrowhead=empty];
    ComputePartition -> GPUPartition     [arrowhead=empty];
    PartitionType -> PrePostPartition    [arrowhead=empty];
    PartitionType -> VisualizationPartition  [arrowhead=empty];
    PartitionType -> CompilationPartition    [arrowhead=empty];
    PartitionType -> ArchivePartition        [arrowhead=empty];

    // System hierarchy
    System -> Supercomputer         [arrowhead=empty];
    System -> HPCCenter             [arrowhead=empty];
    System -> HardwareGeneration    [arrowhead=empty];

    // Infrastructure
    Infrastructure -> CoolingSystem     [arrowhead=empty];
    Infrastructure -> EnergyManagement  [arrowhead=empty];

    // Software (not subclass of HPCResource — note with dashed border)
    Software -> ResourceManager     [arrowhead=empty];
    Software -> Compiler            [arrowhead=empty];
    Software -> OperatingSystem     [arrowhead=empty];
    Software -> ParallelLibrary     [arrowhead=empty];
    Software -> ModuleEnvironment   [arrowhead=empty];

    // QuantitativeValue
    QuantitativeValue -> DieSize          [arrowhead=empty];
    QuantitativeValue -> Lifetime         [arrowhead=empty];
    QuantitativeValue -> MemoryCapacity   [arrowhead=empty];
    QuantitativeValue -> StorageCapacity  [arrowhead=empty];
    QuantitativeValue -> Frequency        [arrowhead=empty];
    QuantitativeValue -> Bandwidth        [arrowhead=empty];
    QuantitativeValue -> Throughput       [arrowhead=empty];
    QuantitativeValue -> PowerConsumption [arrowhead=empty];
    PowerConsumption -> TDP               [arrowhead=empty];
    PerformanceMetric -> PeakPerformance  [arrowhead=empty];

    // Organization
    Organization -> FundingAgency   [arrowhead=empty];


    // ===========================================================
    // KEY OBJECT PROPERTIES  (dashed arrows, labeled)
    // ===========================================================

    // HPCCenter relations
    HPCCenter -> Supercomputer    [label="hosts", style=dashed, color="#E74C3C", fontcolor="#E74C3C"];
    HPCCenter -> Organization     [label="operatedBy", style=dashed, color="#E74C3C", fontcolor="#E74C3C"];
    HPCCenter -> FundingAgency    [label="fundedBy", style=dashed, color="#E74C3C", fontcolor="#E74C3C"];
    HPCCenter -> StorageMount     [label="hasStorageMount", style=dashed, color="#E74C3C", fontcolor="#E74C3C"];

    // Supercomputer relations
    Supercomputer -> Partition          [label="hasPartition", style=dashed, color="#2E86C1", fontcolor="#2E86C1"];
    Supercomputer -> HardwareGeneration [label="hasGeneration", style=dashed, color="#2E86C1", fontcolor="#2E86C1"];
    Supercomputer -> ComputeNode        [label="composedOf", style=dashed, color="#2E86C1", fontcolor="#2E86C1"];
    Supercomputer -> FileSystem         [label="usesFileSystem", style=dashed, color="#2E86C1", fontcolor="#2E86C1"];
    Supercomputer -> ResourceManager    [label="usesResourceManager", style=dashed, color="#2E86C1", fontcolor="#2E86C1"];
    Supercomputer -> FrontendNode       [label="hasFrontendNodes", style=dashed, color="#2E86C1", fontcolor="#2E86C1"];
    Supercomputer -> PeakPerformance    [label="hasPeakPerformance", style=dashed, color="#2E86C1", fontcolor="#2E86C1"];

    // Partition relations
    Partition -> PartitionType      [label="hasPartitionType", style=dashed, color="#D35400", fontcolor="#D35400"];
    Partition -> QoS                [label="hasQoS", style=dashed, color="#D35400", fontcolor="#D35400"];
    Partition -> ComputeNode        [label="usesNodeType", style=dashed, color="#D35400", fontcolor="#D35400"];
    Partition -> Compiler           [label="supportsCompiler", style=dashed, color="#D35400", fontcolor="#D35400"];
    Partition -> SoftwareVersion    [label="requiresModule", style=dashed, color="#D35400", fontcolor="#D35400"];

    // ComputeNode relations
    ComputeNode -> Partition        [label="belongsToPartition", style=dashed, color="#1E8449", fontcolor="#1E8449"];
    ComputeNode -> Interconnect     [label="connectedVia", style=dashed, color="#1E8449", fontcolor="#1E8449"];
    ComputeNode -> Rack             [label="housedInRack", style=dashed, color="#1E8449", fontcolor="#1E8449"];
    ComputeNode -> OperatingSystem  [label="runsOS", style=dashed, color="#1E8449", fontcolor="#1E8449"];

    // AcceleratedNode → AcceleratorCard → GPU
    AcceleratedNode -> AcceleratorCard [label="hasAcceleratorCard", style=dashed, color="#8E44AD", fontcolor="#8E44AD"];
    AcceleratorCard -> GPU             [label="hostsAccelerator", style=dashed, color="#8E44AD", fontcolor="#8E44AD"];

    // ScalarNode equipped with CPU (OWL restriction: allValuesFrom CPU)
    ScalarNode -> CPU               [label="equippedWith\n(only CPUs)", style=dashed, color="#148F77", fontcolor="#148F77"];

    // Processor relations
    Processor -> Core           [label="hasCore", style=dashed, color="#922B21", fontcolor="#922B21"];
    Processor -> Frequency      [label="hasFrequency", style=dashed, color="#922B21", fontcolor="#922B21"];
    Processor -> DieSize        [label="hasDieSize", style=dashed, color="#922B21", fontcolor="#922B21"];
    Processor -> TDP            [label="hasTDP", style=dashed, color="#922B21", fontcolor="#922B21"];
    GPU -> MemoryCapacity       [label="gpuMemory", style=dashed, color="#922B21", fontcolor="#922B21"];

    // Memory / Storage relations
    RAM -> MemoryCapacity       [label="hasMemoryCapacity", style=dashed, color="#7D3C98", fontcolor="#7D3C98"];
    HBMMemory -> MemoryCapacity [label="hasMemoryCapacity", style=dashed, color="#7D3C98", fontcolor="#7D3C98"];
    FileSystem -> StorageCapacity [label="hasStorageCapacity", style=dashed, color="#7D3C98", fontcolor="#7D3C98"];
    FileSystem -> Throughput    [label="hasThroughput", style=dashed, color="#7D3C98", fontcolor="#7D3C98"];
    StorageMount -> FileSystem  [label="mountedOn", style=dashed, color="#7D3C98", fontcolor="#7D3C98"];
    Interconnect -> Bandwidth   [label="hasBandwidth", style=dashed, color="#7D3C98", fontcolor="#7D3C98"];

    // Software version
    SoftwareVersion -> Software [label="isSoftware", style=dashed, color="#5D6D7E", fontcolor="#5D6D7E"];
}
