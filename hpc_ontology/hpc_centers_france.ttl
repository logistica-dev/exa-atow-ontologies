@prefix exa-atow: <https://raw.githubusercontent.com/logistica-dev/exa-atow-ontologies/refs/heads/main/hpc_ontology/exaatow_hpc_ontology.ttl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .

# ================================================================
# Exa-AToW — Canonical Instances: French National HPC Centers
# Sources:
#   - IDRIS: https://www.idris.fr/eng/jean-zay/
#   - TGCC:  https://hpc.cea.fr/tgcc-public/
#   - Cines: https://www.cines.fr/calcul/adastra/
#            https://dci.dci-gitlab.cines.fr/webextranet/architecture/
# Last reviewed: 2026-03-09
# ================================================================


# ================================================================
# 1. ORGANIZATIONS
# ================================================================

exa-atow:CNRS rdf:type exa-atow:Organization ;
    rdfs:label "CNRS"@fr , "CNRS"@en ;
    skos:prefLabel "Centre National de la Recherche Scientifique"@fr ,
                   "National Centre for Scientific Research"@en ;
    exa-atow:website "https://www.cnrs.fr"^^xsd:anyURI .

exa-atow:CEA rdf:type exa-atow:Organization ;
    rdfs:label "CEA"@fr ;
    skos:prefLabel "Commissariat à l'Énergie Atomique et aux Énergies Alternatives"@fr ,
                   "French Alternative Energies and Atomic Energy Commission"@en ;
    exa-atow:website "https://www.cea.fr"^^xsd:anyURI .

exa-atow:FranceUniversites rdf:type exa-atow:Organization ;
    rdfs:label "France Universités"@fr ;
    skos:prefLabel "France Universités"@fr ;
    exa-atow:website "https://franceuniversites.fr"^^xsd:anyURI .

exa-atow:GENCI rdf:type exa-atow:FundingAgency ;
    rdfs:label "GENCI"@fr ;
    skos:prefLabel "Grand Équipement National de Calcul Intensif"@fr ,
                   "Grand Equipment for National Intensive Computing"@en ;
    exa-atow:website "https://www.genci.fr"^^xsd:anyURI .

exa-atow:France2030 rdf:type exa-atow:FundingAgency ;
    rdfs:label "France 2030"@fr ;
    skos:prefLabel "France 2030"@fr ;
    exa-atow:website "https://www.gouvernement.fr/france-2030"^^xsd:anyURI .


# ================================================================
# 2. HPC CENTERS
# ================================================================

exa-atow:IDRIS rdf:type exa-atow:HPCCenter ;
    rdfs:label "IDRIS"@fr ;
    skos:prefLabel "Institut du Développement et des Ressources en Informatique Scientifique"@fr ,
                   "Institute for Development and Resources in Intensive Scientific Computing"@en ;
    exa-atow:shortName "IDRIS" ;
    exa-atow:location "Orsay, France" ;
    exa-atow:website "https://www.idris.fr"^^xsd:anyURI ;
    exa-atow:operatedBy exa-atow:CNRS ;
    exa-atow:hosts exa-atow:JeanZay .

exa-atow:TGCC rdf:type exa-atow:HPCCenter ;
    rdfs:label "TGCC"@fr ;
    skos:prefLabel "Très Grand Centre de Calcul du CEA"@fr ,
                   "CEA Very Large Computing Center"@en ;
    exa-atow:shortName "TGCC" ;
    exa-atow:location "Bruyères-le-Châtel, France" ;
    exa-atow:website "https://www-hpc.cea.fr"^^xsd:anyURI ;
    exa-atow:operatedBy exa-atow:CEA ;
    exa-atow:hosts exa-atow:JoliotCurie , exa-atow:Topaze .

exa-atow:Cines rdf:type exa-atow:HPCCenter ;
    rdfs:label "Cines"@fr ;
    skos:prefLabel "Centre Informatique National de l'Enseignement Supérieur"@fr ,
                   "National Computing Center for Higher Education"@en ;
    exa-atow:shortName "Cines" ;
    exa-atow:location "Montpellier, France" ;
    exa-atow:website "https://www.cines.fr"^^xsd:anyURI ;
    exa-atow:operatedBy exa-atow:FranceUniversites ;
    exa-atow:hosts exa-atow:Adastra .


# ================================================================
# 3. SUPERCOMPUTERS
# ================================================================

# ----------------------------------------------------------------
# 3.1  Jean Zay (IDRIS/CNRS)
# ----------------------------------------------------------------
# Eviden BullSequana XH3000 (H100 partition) + HPE SGI 8600 (older partitions)
# Peak performance: 125.9 PFLOP/s (as of July 2024)
# ----------------------------------------------------------------

exa-atow:JeanZay rdf:type exa-atow:Supercomputer ;
    rdfs:label "Jean Zay" ;
    skos:prefLabel "Jean Zay"@fr , "Jean Zay"@en ;
    exa-atow:shortName "jean-zay" ;
    exa-atow:description "GENCI/IDRIS supercomputer composed of an Eviden BullSequana XH3000 (H100) part and an HPE SGI 8600 part. Named after Jean Zay, minister of the French Third Republic."@en ;
    exa-atow:location "Orsay, France" ;
    exa-atow:commissioningDate "2019-01-01"^^xsd:date ;
    exa-atow:documentationURL "https://www.idris.fr/eng/jean-zay/"^^xsd:anyURI ;
    exa-atow:fundedBy exa-atow:GENCI , exa-atow:France2030 ;
    exa-atow:usesResourceManager exa-atow:SLURM ;
    exa-atow:hasPeakPerformance exa-atow:JeanZay_Rpeak ;
    # Partitions
    exa-atow:hasPartition
        exa-atow:JZ_cpu_p1 ,
        exa-atow:JZ_gpu_p13 ,
        exa-atow:JZ_gpu_p2 ,
        exa-atow:JZ_gpu_p5 ,
        exa-atow:JZ_gpu_p6 ,
        exa-atow:JZ_prepost ,
        exa-atow:JZ_visu ,
        exa-atow:JZ_compil ,
        exa-atow:JZ_archive ;
    # Interconnects
    exa-atow:composedOf exa-atow:JZ_OmniPath , exa-atow:JZ_InfiniBandNDR ;
    # Storage
    exa-atow:usesFileSystem exa-atow:JZ_Lustre_SSD , exa-atow:JZ_Lustre_HDD ;
    exa-atow:hasStorageMount
        exa-atow:JZ_WORK ,
        exa-atow:JZ_SCRATCH ,
        exa-atow:JZ_STORE .

exa-atow:JeanZay_Rpeak rdf:type exa-atow:PeakPerformance ;
    exa-atow:hasValue "125.9"^^xsd:decimal ;
    exa-atow:hasUnit "PFLOP/s" .

# --- Jean Zay: Interconnects ---

exa-atow:JZ_OmniPath rdf:type exa-atow:IntelOmniPath ;
    rdfs:label "Jean Zay Intel OmniPath" ;
    rdfs:comment "100 Gb/s OPA — connects HPE SGI 8600 scalar and V100/A100 nodes (1 link/scalar node, 4 links/accelerated node)."@en .

exa-atow:JZ_InfiniBandNDR rdf:type exa-atow:InfiniBandNDR ;
    rdfs:label "Jean Zay InfiniBand NDR" ;
    rdfs:comment "400 Gb/s NDR InfiniBand — connects Eviden BullSequana XH3000 H100 nodes (4 links per node)."@en .

# --- Jean Zay: File Systems ---

exa-atow:JZ_Lustre_SSD rdf:type exa-atow:Lustre ;
    rdfs:label "Jean Zay Lustre SSD" ;
    rdfs:comment "Parallel Lustre file system on SSD (GridScaler GS18K SSD). Added in summer 2020 extension."@en ;
    exa-atow:hasStorageCapacity [ rdf:type exa-atow:StorageCapacity ;
        exa-atow:hasValue "2.5"^^xsd:decimal ; exa-atow:hasUnit "PB" ] .

exa-atow:JZ_Lustre_HDD rdf:type exa-atow:Lustre ;
    rdfs:label "Jean Zay Lustre HDD" ;
    rdfs:comment "Parallel Lustre file system on HDDs. Capacity > 30 PB."@en ;
    exa-atow:hasStorageCapacity [ rdf:type exa-atow:StorageCapacity ;
        exa-atow:hasValue "30"^^xsd:decimal ; exa-atow:hasUnit "PB" ] .

# --- Jean Zay: Storage Mounts ---

exa-atow:JZ_WORK rdf:type exa-atow:StorageMount ;
    rdfs:label "Jean Zay $WORK" ;
    exa-atow:mountPath "$WORK" ;
    exa-atow:isPurged false ;
    exa-atow:mountedOn exa-atow:JZ_Lustre_SSD .

exa-atow:JZ_SCRATCH rdf:type exa-atow:StorageMount ;
    rdfs:label "Jean Zay $SCRATCH" ;
    exa-atow:mountPath "$SCRATCH" ;
    exa-atow:isPurged true ;
    rdfs:comment "High-speed scratch on Lustre SSD. Automatically purged."@en ;
    exa-atow:mountedOn exa-atow:JZ_Lustre_SSD .

exa-atow:JZ_STORE rdf:type exa-atow:StorageMount ;
    rdfs:label "Jean Zay $STORE" ;
    exa-atow:mountPath "$STORE" ;
    exa-atow:isPurged false ;
    rdfs:comment "Long-term storage. Since July 2024 only accessible from login nodes, prepost, archive, compil and visu partitions — not from compute nodes."@en ;
    exa-atow:mountedOn exa-atow:JZ_Lustre_HDD .

# --- Jean Zay: Node Types ---

exa-atow:JZ_Node_CascadeLake_40c rdf:type exa-atow:ScalarNode ;
    rdfs:label "Jean Zay CPU node (Cascade Lake 40-core)" ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 192 ;
    exa-atow:equippedWithProcessor exa-atow:Intel_CascadeLake_6248 .

exa-atow:JZ_Node_V100_4GPU rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Jean Zay V100 4-GPU node" ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 192 ;
    exa-atow:gpuCount 4 ;
    exa-atow:linkCount 4 ;
    exa-atow:equippedWithProcessor exa-atow:Intel_CascadeLake_6248 ;
    exa-atow:hasAcceleratorCard exa-atow:NVIDIA_V100_SXM2_32GB .

exa-atow:JZ_Node_V100_8GPU_360 rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Jean Zay V100 8-GPU node (360 GB, gpu_p2s)" ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 360 ;
    exa-atow:gpuCount 8 ;
    exa-atow:equippedWithProcessor exa-atow:Intel_CascadeLake_6226 .

exa-atow:JZ_Node_V100_8GPU_720 rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Jean Zay V100 8-GPU node (720 GB, gpu_p2l)" ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 720 ;
    exa-atow:gpuCount 8 ;
    exa-atow:equippedWithProcessor exa-atow:Intel_CascadeLake_6226 .

exa-atow:JZ_Node_A100_8GPU rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Jean Zay A100 8-GPU node (AMD EPYC Milan)" ;
    rdfs:comment "52 nodes. AMD EPYC 7543 Milan (unlike other JZ partitions which use Intel). Required: module load arch/a100 and #SBATCH -C a100."@en ;
    exa-atow:socketCount 1 ;
    exa-atow:ramPerNode 512 ;
    exa-atow:gpuCount 8 ;
    exa-atow:linkCount 4 ;
    exa-atow:equippedWithProcessor exa-atow:AMD_EPYC_7543_Milan ;
    exa-atow:hasAcceleratorCard exa-atow:NVIDIA_A100_SXM4_80GB .

exa-atow:JZ_Node_H100_4GPU rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Jean Zay H100 4-GPU node (Eviden BullSequana XH3000)" ;
    rdfs:comment "364 nodes. Required: module load arch/h100 and #SBATCH -C h100."@en ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 512 ;
    exa-atow:gpuCount 4 ;
    exa-atow:linkCount 4 ;
    exa-atow:hasAcceleratorCard exa-atow:NVIDIA_H100_SXM5_80GB .

# --- Jean Zay: Partitions ---

exa-atow:JZ_cpu_p1 rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay cpu_p1" ;
    exa-atow:partitionName "cpu_p1" ;
    exa-atow:nodeCount 720 ;
    exa-atow:maxWallTime "100:00:00" ;
    exa-atow:defaultWallTime "00:10:00" ;
    exa-atow:allocatedFromQuota true ;
    exa-atow:usesNodeType exa-atow:JZ_Node_CascadeLake_40c ;
    exa-atow:documentationURL "https://www.idris.fr/eng/jean-zay/cpu/jean-zay-cpu-exec_partition_slurm-eng.html"^^xsd:anyURI ;
    rdfs:comment "Default CPU partition. 720 nodes (reduced from 1528 after decommissioning of 808 nodes on Feb 5, 2024)."@en ;
    exa-atow:hasQoS exa-atow:JZ_qos_cpu_t3 , exa-atow:JZ_qos_cpu_t4 , exa-atow:JZ_qos_cpu_dev .

exa-atow:JZ_gpu_p13 rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay gpu_p13" ;
    exa-atow:partitionName "gpu_p13" ;
    exa-atow:nodeCount 396 ;
    exa-atow:maxWallTime "100:00:00" ;
    exa-atow:defaultWallTime "00:10:00" ;
    exa-atow:allocatedFromQuota true ;
    exa-atow:usesNodeType exa-atow:JZ_Node_V100_4GPU ;
    rdfs:comment "Default GPU partition for V100 GPU-hour holders. Mixes v100-16g and v100-32g nodes (4-GPU, 160 GB RAM). 396 nodes after decommissioning on Feb 5, 2024."@en ;
    exa-atow:hasQoS exa-atow:JZ_qos_gpu_t3 , exa-atow:JZ_qos_gpu_t4 , exa-atow:JZ_qos_gpu_dev .

exa-atow:JZ_gpu_p2 rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay gpu_p2" ;
    exa-atow:partitionName "gpu_p2" ;
    exa-atow:maxWallTime "100:00:00" ;
    exa-atow:defaultWallTime "00:10:00" ;
    exa-atow:allocatedFromQuota true ;
    rdfs:comment "8-GPU V100 nodes partition. Sub-partitions: gpu_p2s (360 GB/node) and gpu_p2l (720 GB/node)."@en ;
    exa-atow:hasQoS exa-atow:JZ_qos_gpu_t3 , exa-atow:JZ_qos_gpu_t4 , exa-atow:JZ_qos_gpu_dev .

exa-atow:JZ_gpu_p5 rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay gpu_p5" ;
    exa-atow:partitionName "gpu_p5" ;
    exa-atow:nodeCount 52 ;
    exa-atow:maxWallTime "20:00:00" ;
    exa-atow:defaultWallTime "00:10:00" ;
    exa-atow:allocatedFromQuota true ;
    exa-atow:usesNodeType exa-atow:JZ_Node_A100_8GPU ;
    exa-atow:requiresModule exa-atow:JZ_module_arch_a100 ;
    rdfs:comment "A100 GPU partition (extension June 2022). 52 nodes, 8×A100 SXM4 80GB per node. AMD EPYC Milan CPUs. Requires: module load arch/a100 and #SBATCH -C a100."@en ;
    exa-atow:documentationURL "https://www.idris.fr/eng/jean-zay/gpu/jean-zay-gpu-exec_partition_slurm-eng.html"^^xsd:anyURI ;
    exa-atow:hasQoS exa-atow:JZ_qos_a100_t3 , exa-atow:JZ_qos_a100_dev .

exa-atow:JZ_gpu_p6 rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay gpu_p6" ;
    exa-atow:partitionName "gpu_p6" ;
    exa-atow:nodeCount 364 ;
    exa-atow:maxWallTime "100:00:00" ;
    exa-atow:defaultWallTime "00:10:00" ;
    exa-atow:allocatedFromQuota true ;
    exa-atow:usesNodeType exa-atow:JZ_Node_H100_4GPU ;
    exa-atow:requiresModule exa-atow:JZ_module_arch_h100 ;
    rdfs:comment "H100 GPU partition (extension summer 2024, Eviden BullSequana XH3000). 364 nodes, 4×H100 SXM5 80GB per node. Requires: module load arch/h100 and #SBATCH -C h100."@en ;
    exa-atow:documentationURL "https://www.idris.fr/eng/jean-zay/gpu/jean-zay-gpu-exec_partition_slurm-eng.html"^^xsd:anyURI ;
    exa-atow:hasQoS exa-atow:JZ_qos_gpu_t3 , exa-atow:JZ_qos_gpu_t4 , exa-atow:JZ_qos_gpu_dev .

exa-atow:JZ_prepost rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay prepost" ;
    exa-atow:partitionName "prepost" ;
    exa-atow:maxWallTime "20:00:00" ;
    exa-atow:defaultWallTime "02:00:00" ;
    exa-atow:allocatedFromQuota false ;
    rdfs:comment "Pre/post-processing partition (jean-zay-pp nodes). Not deducted from allocation. STORE accessible from here."@en .

exa-atow:JZ_visu rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay visu" ;
    exa-atow:partitionName "visu" ;
    exa-atow:maxWallTime "04:00:00" ;
    exa-atow:defaultWallTime "00:10:00" ;
    exa-atow:allocatedFromQuota false ;
    rdfs:comment "Visualization partition (jean-zay-visu nodes). Not deducted from allocation."@en .

exa-atow:JZ_compil rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay compil" ;
    exa-atow:partitionName "compil" ;
    exa-atow:maxWallTime "20:00:00" ;
    exa-atow:defaultWallTime "02:00:00" ;
    exa-atow:allocatedFromQuota false ;
    rdfs:comment "Compilation partition. For jobs requiring more CPU time than allowed on login nodes."@en .

exa-atow:JZ_archive rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay archive" ;
    exa-atow:partitionName "archive" ;
    exa-atow:maxWallTime "20:00:00" ;
    exa-atow:defaultWallTime "02:00:00" ;
    exa-atow:allocatedFromQuota false ;
    rdfs:comment "Data management partition (file copies, archive creation)."@en .

# --- Jean Zay: QoS ---

exa-atow:JZ_qos_cpu_t3 rdf:type exa-atow:QoS ;
    rdfs:label "qos_cpu-t3" ;
    exa-atow:partitionName "qos_cpu-t3" ;
    exa-atow:maxWallTime "20:00:00" .

exa-atow:JZ_qos_cpu_t4 rdf:type exa-atow:QoS ;
    rdfs:label "qos_cpu-t4" ;
    exa-atow:partitionName "qos_cpu-t4" ;
    exa-atow:maxWallTime "100:00:00" .

exa-atow:JZ_qos_cpu_dev rdf:type exa-atow:QoS ;
    rdfs:label "qos_cpu-dev" ;
    exa-atow:partitionName "qos_cpu-dev" ;
    exa-atow:maxWallTime "02:00:00" ;
    rdfs:comment "Dev/test QoS. Max 10 simultaneous jobs per user."@en .

exa-atow:JZ_qos_gpu_t3 rdf:type exa-atow:QoS ;
    rdfs:label "qos_gpu-t3" ;
    exa-atow:partitionName "qos_gpu-t3" ;
    exa-atow:maxWallTime "20:00:00" .

exa-atow:JZ_qos_gpu_t4 rdf:type exa-atow:QoS ;
    rdfs:label "qos_gpu-t4" ;
    exa-atow:partitionName "qos_gpu-t4" ;
    exa-atow:maxWallTime "100:00:00" .

exa-atow:JZ_qos_gpu_dev rdf:type exa-atow:QoS ;
    rdfs:label "qos_gpu-dev" ;
    exa-atow:partitionName "qos_gpu-dev" ;
    exa-atow:maxWallTime "02:00:00" .

exa-atow:JZ_qos_a100_t3 rdf:type exa-atow:QoS ;
    rdfs:label "qos_gpu-t3 (A100)" ;
    exa-atow:partitionName "qos_gpu-t3" ;
    exa-atow:maxWallTime "20:00:00" .

exa-atow:JZ_qos_a100_dev rdf:type exa-atow:QoS ;
    rdfs:label "qos_gpu-dev (A100)" ;
    exa-atow:partitionName "qos_gpu-dev" ;
    exa-atow:maxWallTime "02:00:00" .

# --- Jean Zay: SoftwareVersion modules ---

exa-atow:JZ_module_arch_a100 rdf:type exa-atow:SoftwareVersion ;
    rdfs:label "arch/a100" ;
    exa-atow:versionNumber "arch/a100" ;
    exa-atow:isSoftware exa-atow:ModuleEnvironment ;
    rdfs:comment "Must be loaded before submitting to gpu_p5. Provides A100-compatible compilers and libraries including AOCC."@en .

exa-atow:JZ_module_arch_h100 rdf:type exa-atow:SoftwareVersion ;
    rdfs:label "arch/h100" ;
    exa-atow:versionNumber "arch/h100" ;
    exa-atow:isSoftware exa-atow:ModuleEnvironment ;
    rdfs:comment "Must be loaded before submitting to gpu_p6. Provides H100-compatible compilers and libraries."@en .


# ================================================================
# 4. JOLIOT-CURIE / IRENE (TGCC/CEA)
# ================================================================
# Bull Sequana X1000. PBS/ccc_msub scheduler.
# Partitions: skylake (Intel Skylake), rome (AMD Rome), knl, xlarge, v100
# ----------------------------------------------------------------

exa-atow:JoliotCurie rdf:type exa-atow:Supercomputer ;
    rdfs:label "Joliot-Curie / Irène" ;
    skos:prefLabel "Joliot-Curie (Irène)"@fr ;
    exa-atow:shortName "irene" ;
    exa-atow:description "GENCI/TGCC supercomputer (Bull Sequana X1000). Named after Irène Joliot-Curie. Hosted at TGCC, Bruyères-le-Châtel. Uses the ccc_msub/PBS scheduler."@en ;
    exa-atow:location "Bruyères-le-Châtel, France" ;
    exa-atow:commissioningDate "2017-01-01"^^xsd:date ;
    exa-atow:documentationURL "https://hpc.cea.fr/tgcc-public/en/html/tgcc-public.html"^^xsd:anyURI ;
    exa-atow:fundedBy exa-atow:GENCI ;
    exa-atow:usesResourceManager exa-atow:PBS ;
    exa-atow:hasPeakPerformance exa-atow:JoliotCurie_Rpeak ;
    exa-atow:hasPartition
        exa-atow:Irene_skylake ,
        exa-atow:Irene_rome ,
        exa-atow:Irene_xlarge ,
        exa-atow:Irene_gpu_v100 ;
    exa-atow:hasStorageMount
        exa-atow:Irene_HOME ,
        exa-atow:Irene_WORK ,
        exa-atow:Irene_SCRATCH ,
        exa-atow:Irene_STORE .

exa-atow:JoliotCurie_Rpeak rdf:type exa-atow:PeakPerformance ;
    exa-atow:hasValue "22"^^xsd:decimal ;
    exa-atow:hasUnit "PFLOP/s" .

# --- Irène: Node Types ---

exa-atow:Irene_Node_Skylake rdf:type exa-atow:ScalarNode ;
    rdfs:label "Irène Skylake node" ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 192 ;
    exa-atow:equippedWithProcessor exa-atow:Intel_Skylake_8168 ;
    rdfs:comment "1,656 dual-socket Intel Skylake 8168 nodes (24 cores/socket, 2.7 GHz). 79,488 total cores."@en .

exa-atow:Irene_Node_Rome rdf:type exa-atow:ScalarNode ;
    rdfs:label "Irène Rome node (AMD)" ;
    exa-atow:socketCount 2 ;
    rdfs:comment "AMD EPYC Rome partition (Irène-AMD). 2×AMD Rome processors."@en .

exa-atow:Irene_Node_Xlarge rdf:type exa-atow:PrePostNode ;
    rdfs:label "Irène xlarge node" ;
    exa-atow:ramPerNode 3072 ;
    rdfs:comment "5 large-memory nodes (3 TB RAM/node) for pre/post-processing. Also equipped with NVIDIA P100 co-processor."@en .

exa-atow:Irene_Node_V100 rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Irène V100 GPU node" ;
