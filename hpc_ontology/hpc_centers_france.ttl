    exa-atow:partitionName "genoa" ;
    exa-atow:nodeCount 536 ;
    exa-atow:allocatedFromQuota true ;
    exa-atow:usesNodeType exa-atow:Adastra_Node_Genoa ;
    rdfs:comment "Adastra-M CPU partition. 536 nodes × 2×EPYC Genoa 96-core, 768 GiB DDR5."@en .

exa-atow:Adastra_visu rdf:type exa-atow:Partition ;
