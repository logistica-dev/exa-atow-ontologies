# ================================================================
# 6. ADASTRA (Cines)
# ================================================================
# HPE Cray EX4000. Scheduler: Slurm.
# GPU partition: AMD EPYC Trento + 4×AMD MI250X (8 GCDs/node)
# Scalar partition: AMD EPYC Genoa (update: Adastra-M extension)
# ----------------------------------------------------------------

exa-atow:Adastra rdf:type exa-atow:Supercomputer ;
    rdfs:label "Adastra" ;
    skos:prefLabel "Adastra"@fr ;
    exa-atow:shortName "adastra" ;
    exa-atow:description "GENCI/Cines supercomputer (HPE Cray EX4000). Features AMD MI250X and MI300A GPU accelerators and AMD EPYC CPUs. Water-cooled, PUE ~1.10."@en ;
    exa-atow:location "Montpellier, France" ;
    exa-atow:commissioningDate "2022-09-01"^^xsd:date ;
    exa-atow:documentationURL "https://dci.dci-gitlab.cines.fr/webextranet/architecture/index.html"^^xsd:anyURI ;
    exa-atow:fundedBy exa-atow:GENCI ;
    exa-atow:usesResourceManager exa-atow:SLURM ;
    exa-atow:hasPartition
        exa-atow:Adastra_MI250X ,
        exa-atow:Adastra_MI300A ,
        exa-atow:Adastra_cpu ,
        exa-atow:Adastra_visu ;
    exa-atow:usesFileSystem exa-atow:Adastra_Lustre_HOME , exa-atow:Adastra_Lustre_SCRATCH ;
    exa-atow:hasStorageMount
        exa-atow:Adastra_HOME ,
        exa-atow:Adastra_SCRATCH ,
        exa-atow:Adastra_SCRATCHDIR ,
        exa-atow:Adastra_WORK ,
        exa-atow:Adastra_WORKDIR ,
        exa-atow:Adastra_STORE .

# --- Adastra: File Systems ---

exa-atow:Adastra_Lustre_HOME rdf:type exa-atow:Lustre ;
    rdfs:label "Adastra Lustre HOME" ;
    rdfs:comment "ClusterStor E1000 SSD. 125 TiB capacity, 77 GiB/s read, 34 GiB/s write."@en ;
    exa-atow:hasStorageCapacity [ rdf:type exa-atow:StorageCapacity ;
        exa-atow:hasValue "125"^^xsd:decimal ; exa-atow:hasUnit "TiB" ] ;
    exa-atow:hasThroughput [ rdf:type exa-atow:Throughput ;
        exa-atow:hasValue "77"^^xsd:decimal ; exa-atow:hasUnit "GiB/s" ] .

exa-atow:Adastra_Lustre_SCRATCH rdf:type exa-atow:Lustre ;
    rdfs:label "Adastra Lustre SCRATCH" ;
    rdfs:comment "ClusterStor E1000 SSD. 1.89 PiB capacity, 1086 GiB/s read, 786 GiB/s write."@en ;
    exa-atow:hasStorageCapacity [ rdf:type exa-atow:StorageCapacity ;
        exa-atow:hasValue "1.89"^^xsd:decimal ; exa-atow:hasUnit "PiB" ] ;
    exa-atow:hasThroughput [ rdf:type exa-atow:Throughput ;
        exa-atow:hasValue "1086"^^xsd:decimal ; exa-atow:hasUnit "GiB/s" ] .

# --- Adastra: Storage Mounts ---

exa-atow:Adastra_HOME rdf:type exa-atow:StorageMount ;
    rdfs:label "Adastra $SHAREDHOMEDIR" ;
    exa-atow:mountPath "$SHAREDHOMEDIR" ;
    exa-atow:isPurged false ;
    rdfs:comment "Scripts and tools, shared with project members. Never purged, backed up."@en ;
    exa-atow:mountedOn exa-atow:Adastra_Lustre_HOME .

exa-atow:Adastra_SCRATCH rdf:type exa-atow:StorageMount ;
    rdfs:label "Adastra $SHAREDSCRATCHDIR" ;
    exa-atow:mountPath "$SHAREDSCRATCHDIR" ;
    exa-atow:isPurged true ;
    exa-atow:quota "17.6 TB" ;
    rdfs:comment "Short-term shared scratch (project-wide). Purged every 30 days. Default quota: 17.6 TB."@en ;
    exa-atow:mountedOn exa-atow:Adastra_Lustre_SCRATCH .

exa-atow:Adastra_SCRATCHDIR rdf:type exa-atow:StorageMount ;
    rdfs:label "Adastra $SCRATCHDIR" ;
    exa-atow:mountPath "$SCRATCHDIR" ;
    exa-atow:isPurged true ;
    rdfs:comment "Short-term per-user scratch. Purged every 30 days."@en ;
    exa-atow:mountedOn exa-atow:Adastra_Lustre_SCRATCH .

exa-atow:Adastra_WORK rdf:type exa-atow:StorageMount ;
    rdfs:label "Adastra $SHAREDWORKDIR" ;
    exa-atow:mountPath "$SHAREDWORKDIR" ;
    exa-atow:isPurged false ;
    exa-atow:quota "4.76 TB" ;
    rdfs:comment "Mid-term shared work space (project-wide). Never purged. Default quota: 4.76 TB."@en .

exa-atow:Adastra_WORKDIR rdf:type exa-atow:StorageMount ;
    rdfs:label "Adastra $WORKDIR" ;
    exa-atow:mountPath "$WORKDIR" ;
    exa-atow:isPurged false ;
    rdfs:comment "Mid-term per-user work space. Never purged."@en .

exa-atow:Adastra_STORE rdf:type exa-atow:StorageMount ;
    rdfs:label "Adastra $STORE" ;
    exa-atow:mountPath "$STORE" ;
    exa-atow:isPurged false ;
    rdfs:comment "Long-term per-user storage. Never purged, backed up."@en .

# --- Adastra: Node Types ---

exa-atow:Adastra_Node_MI250X rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Adastra MI250X GPU node" ;
    rdfs:comment "356 nodes. 1×AMD EPYC Trento 7A53 (64 cores, 2.0 GHz) + 4×AMD MI250X (8 GCDs = 8 virtual GPUs). 256 GiB DDR4 CPU memory, 512 GiB HBM2 GPU memory. 4 Slingshot 200 Gb/s NICs."@en ;
    exa-atow:socketCount 1 ;
    exa-atow:ramPerNode 256 ;
    exa-atow:gpuCount 8 ;
    exa-atow:linkCount 4 ;
    exa-atow:equippedWithProcessor exa-atow:AMD_EPYC_7A53_Trento ;
    exa-atow:hasAcceleratorCard exa-atow:AMD_MI250X .

exa-atow:Adastra_Node_MI300A rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Adastra MI300A APU node" ;
    rdfs:comment "28 nodes. 4×AMD MI300A APU (integrated CPU+GPU). 512 GiB HBM2. 4 Slingshot NICs."@en ;
    exa-atow:gpuCount 4 ;
    exa-atow:linkCount 4 ;
    exa-atow:hasAcceleratorCard exa-atow:AMD_MI300A .

exa-atow:Adastra_Node_Genoa rdf:type exa-atow:ScalarNode ;
    rdfs:label "Adastra scalar node (AMD EPYC Genoa)" ;
    rdfs:comment "Adastra-M extension: 536 scalar nodes. 2×AMD EPYC Genoa 9654 (96 cores, 2.4 GHz). 768 GiB DDR5-5200. 1 Slingshot NIC."@en ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 768 ;
    exa-atow:linkCount 1 ;
    exa-atow:equippedWithProcessor exa-atow:AMD_EPYC_9654_Genoa .

exa-atow:Adastra_Node_Visu rdf:type exa-atow:VisualizationNode ;
    rdfs:label "Adastra visualization node" ;
    rdfs:comment "12 visu/prepost nodes. 2×AMD EPYC Genoa (96 cores, 2.4 GHz). 2048 GiB DDR5. 2×NVIDIA L40 GPUs. 1 Slingshot NIC."@en ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 2048 ;
    exa-atow:gpuCount 2 .

# --- Adastra: Partitions ---

exa-atow:Adastra_MI250X rdf:type exa-atow:Partition ;
    rdfs:label "Adastra MI250X partition" ;
    exa-atow:partitionName "MI250" ;
    exa-atow:nodeCount 356 ;
    exa-atow:allocatedFromQuota true ;
    exa-atow:usesNodeType exa-atow:Adastra_Node_MI250X ;
    rdfs:comment "Main GPU partition. 356 nodes × 4 AMD MI250X (8 GCDs/node). Constraint: --constraint=MI250."@en ;
