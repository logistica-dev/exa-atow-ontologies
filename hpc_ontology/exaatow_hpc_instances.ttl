# ──── CPU RAM (RAM subclass) ──────────────────────────────────────────────────
inst:Mem_DDR4_3200_256GiB rdf:type exa-atow:RAM ;
    rdfs:label "256 GiB DDR4-3200 (Adastra GPU node CPU RAM)"@en ;
    rdfs:comment "CPU-side RAM for Adastra MI250X accelerated nodes. 256 GiB DDR4-3200 per node."@en ;
    exa-atow:memoryModel "DDR4-3200" ;
    exa-atow:hasMemoryCapacity [
        rdf:type exa-atow:MemoryCapacity ;
        exa-atow:hasValue "256"^^xsd:decimal ;
        exa-atow:hasUnit "GiB"
    ] .

inst:Mem_DDR5_4800_768GiB rdf:type exa-atow:RAM ;
    rdfs:label "768 GiB DDR5-4800 (Adastra scalar node RAM)"@en ;
    rdfs:comment "CPU RAM for Adastra scalar nodes (AMD Genoa). 768 GiB DDR5-4800 per node (12 channels × 32 GiB DIMM × 2 sockets)."@en ;
    exa-atow:memoryModel "DDR5-4800" ;
    exa-atow:hasMemoryCapacity [
        rdf:type exa-atow:MemoryCapacity ;
        exa-atow:hasValue "768"^^xsd:decimal ;
        exa-atow:hasUnit "GiB"
    ] .

inst:Mem_DDR5_4800_2048GiB rdf:type exa-atow:RAM ;
    rdfs:label "2048 GiB DDR5-4800 (Adastra visu/prepost node RAM)"@en ;
    rdfs:comment "CPU RAM for Adastra visualization/prepost nodes. 2048 GiB DDR5-4800 per node (16 channels × 64 GiB DIMM × 2 sockets)."@en ;
    exa-atow:memoryModel "DDR5-4800" ;
    exa-atow:hasMemoryCapacity [
        rdf:type exa-atow:MemoryCapacity ;
        exa-atow:hasValue "2048"^^xsd:decimal ;
        exa-atow:hasUnit "GiB"
    ] .

inst:Mem_DDR5_4800_512GiB rdf:type exa-atow:RAM ;
    rdfs:label "512 GiB DDR5-4800 (Adastra frontend node RAM)"@en ;
    rdfs:comment "CPU RAM for Adastra frontend and transfer nodes. 512 GiB DDR5-4800 per node."@en ;
    exa-atow:memoryModel "DDR5-4800" ;
    exa-atow:hasMemoryCapacity [
        rdf:type exa-atow:MemoryCapacity ;
        exa-atow:hasValue "512"^^xsd:decimal ;
        exa-atow:hasUnit "GiB"
    ] .

# ──── GPU / Accelerator memory (HBM / GDDR) ──────────────────────────────────

inst:Mem_MI250X_HBM_128GiB rdf:type exa-atow:HBMMemory ;
    rdfs:label "128 GiB HBM2e (AMD MI250X card)"@en ;
    rdfs:comment "HBM2e memory on AMD MI250X OAM card. 128 GiB total = 2 GCDs × 64 GiB. Each GCD has its own HBM stack."@en ;
    exa-atow:memoryModel "HBM2e" ;
    exa-atow:hasMemoryCapacity inst:MemCap_128GiB .

inst:Mem_MI300A_HBM_128GiB rdf:type exa-atow:HBMMemory ;
    rdfs:label "128 GiB HBM3 (AMD MI300A package)"@en ;
    rdfs:comment "Unified HBM3 memory on AMD MI300A APU package. Shared between integrated CPU and GPU compute dies. 128 GiB per package."@en ;
    exa-atow:memoryModel "HBM3" ;
    exa-atow:hasMemoryCapacity inst:MemCap_128GiB .

inst:Mem_NvidiaL40_48GiB rdf:type exa-atow:GDDRMemory ;
    rdfs:label "48 GiB GDDR6 (NVIDIA L40)"@en ;
    rdfs:comment "GDDR6 memory on NVIDIA L40 card. 48 GiB per card."@en ;
    exa-atow:memoryModel "GDDR6" ;
    exa-atow:hasMemoryCapacity [
        rdf:type exa-atow:MemoryCapacity ;
        exa-atow:hasValue "48"^^xsd:decimal ;
        exa-atow:hasUnit "GiB"
    ] .

# ──── Local storage ───────────────────────────────────────────────────────────

inst:Storage_SAS_SSD_1_6TiB rdf:type exa-atow:SAS_SSD ;
    rdfs:label "1.6 TiB SAS MU SSD (frontend node)"@en ;
    rdfs:comment "SAS Mixed-Use SSD 1.6 TiB. Frontend nodes are equipped with 4 units configured in RAID10 = 3.2 TiB usable."@en ;
    exa-atow:hasPhysicalStorageCapacity [
        rdf:type exa-atow:StorageCapacity ;
        exa-atow:hasValue "1.6"^^xsd:decimal ;
        exa-atow:hasUnit "TiB"
    ] .

