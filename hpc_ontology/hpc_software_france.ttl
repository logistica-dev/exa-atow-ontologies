@prefix exa-atow: <https://raw.githubusercontent.com/logistica-dev/exa-atow-ontologies/refs/heads/main/hpc_ontology/exaatow_hpc_ontology.ttl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .

# ================================================================
# Exa-AToW — Software Instances: French National HPC Centers
# Covers: Jean Zay (IDRIS), Joliot-Curie/Irène (TGCC), Adastra (Cines)
# Sources:
#   - https://www.idris.fr/eng/jean-zay/cpu/jean-zay-cpu-doc_module-eng.html
#   - https://www-hpc.cea.fr/tgcc-public/en/html/toc/fulldoc/Parallel_programming.html
#   - https://dci.dci-gitlab.cines.fr/webextranet/software_stack/
# Last reviewed: 2026-03-09
# ================================================================


# ================================================================
# 1. RESOURCE MANAGERS
# ================================================================

exa-atow:SLURM rdf:type exa-atow:ResourceManager ;
    rdfs:label "Slurm" ;
    exa-atow:softwareName "Slurm Workload Manager" ;
    exa-atow:documentationURL "https://slurm.schedmd.com"^^xsd:anyURI ;
    rdfs:comment "Used by Jean Zay (IDRIS) and Adastra (Cines). Job submission via sbatch/srun."@en .

exa-atow:PBS rdf:type exa-atow:ResourceManager ;
    rdfs:label "PBS/ccc_msub" ;
    exa-atow:softwareName "Portable Batch System (TGCC/Bridge variant)" ;
    rdfs:comment "Used by Joliot-Curie/Irène and Topaze (TGCC). Job submission via ccc_msub; execution via ccc_mprun. The Bridge middleware wraps PBS directives with #MSUB headers."@en .

exa-atow:ModuleEnvironment rdf:type exa-atow:Software ;
    rdfs:label "Environment Modules" ;
    exa-atow:softwareName "Environment Modules" ;
    rdfs:comment "Module system used on all centers for managing software environments and paths."@en .


# ================================================================
# 2. JEAN ZAY (IDRIS) — SOFTWARE
# ================================================================
# Environment Modules v4.3.1 (lmod-compatible).
# Two separate module trees: standard (skylake) and arch/a100, arch/h100.
# Default MPI: OpenMPI + Intel MPI. CUDA-aware MPI: openmpi/*-cuda.
# ================================================================

# --- Jean Zay: Compilers ---

exa-atow:JZ_sw_gcc rdf:type exa-atow:Compiler ;
    rdfs:label "GCC (Jean Zay)" ;
    exa-atow:softwareName "GNU Compiler Collection" ;
    exa-atow:moduleCommand "module load gcc/<version>" ;
    rdfs:comment "Available versions include 7.3.0, 8.2.0, 8.3.0, 8.4.1, 9.1.0, 10.1.0 (with CUDA/OpenACC support). The gcc/10.1.0-cuda-openacc variant adds GPU directives support."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_intel_compilers rdf:type exa-atow:Compiler ;
    rdfs:label "Intel oneAPI compilers (Jean Zay)" ;
    exa-atow:softwareName "Intel oneAPI C/C++/Fortran compilers" ;
    exa-atow:moduleCommand "module load intel-compilers/<version>" ;
    rdfs:comment "Available versions: 19.0.4, 19.1.3, 2021.9.0. The intel-all/<version> meta-module loads compilers + MKL + MPI + profiling tools together. E.g. module load intel-all/2020.2."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_pgi rdf:type exa-atow:Compiler ;
    rdfs:label "PGI/NVHPC compilers (Jean Zay)" ;
    exa-atow:softwareName "PGI / NVIDIA HPC SDK" ;
    exa-atow:moduleCommand "module load pgi/<version>" ;
    rdfs:comment "Versions 19.10, 20.1, 20.4. Required for OpenACC GPU offloading. Compatible with openmpi/*-cuda as a prerequisite."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

# --- Jean Zay: MPI Libraries ---

exa-atow:JZ_sw_openmpi rdf:type exa-atow:MPILibrary ;
    rdfs:label "OpenMPI (Jean Zay)" ;
    exa-atow:softwareName "Open MPI" ;
    exa-atow:moduleCommand "module load openmpi/<version>" ;
    rdfs:comment "Versions: 3.1.4, 3.1.5, 3.1.6, 4.0.1–4.1.1. CUDA-aware variants: openmpi/*-cuda (e.g. openmpi/4.0.4-cuda). Requires matching compiler (gcc, intel, pgi) to be pre-loaded."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_intel_mpi rdf:type exa-atow:MPILibrary ;
    rdfs:label "Intel MPI (Jean Zay)" ;
    exa-atow:softwareName "Intel MPI Library" ;
    exa-atow:moduleCommand "module load intel-mpi/<version>" ;
    rdfs:comment "Versions: 2019.4–2021.9. Default environment: module load intel-compilers/19.0.4 intel-mpi/19.0.4. Also accessible via intel-all/<version> meta-module."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

# --- Jean Zay: Math Libraries ---

exa-atow:JZ_sw_mkl rdf:type exa-atow:MathLibrary ;
    rdfs:label "Intel MKL (Jean Zay)" ;
    exa-atow:softwareName "Intel Math Kernel Library (MKL)" ;
    exa-atow:moduleCommand "module load intel-all/<version>  # includes MKL" ;
    rdfs:comment "MKL (BLAS, LAPACK, ScaLAPACK, FFT). Included in intel-all/*, accessible via feature/mkl/* flavor modules."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

# --- Jean Zay: I/O Libraries ---

exa-atow:JZ_sw_hdf5 rdf:type exa-atow:IOLibrary ;
    rdfs:label "HDF5 (Jean Zay)" ;
    exa-atow:softwareName "HDF5" ;
    exa-atow:moduleCommand "module load intel-compilers/19.0.4 hdf5/<version>" ;
    rdfs:comment "Hierarchical Data Format 5 library for scientific data I/O."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_netcdf rdf:type exa-atow:IOLibrary ;
    rdfs:label "NetCDF (Jean Zay)" ;
    exa-atow:softwareName "NetCDF" ;
    exa-atow:moduleCommand "module load intel-compilers/19.0.4 netcdf/<version>" ;
    rdfs:comment "Compiled with HDF5 1.10.5, 64-bit addressing. C, Fortran and C++ variants: netcdf/4.7.2-mpi, netcdf-fortran/4.5.2-mpi, netcdf-cxx4/4.3.1-mpi. Auto-loads intel-mpi."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

# --- Jean Zay: AI / ML Frameworks ---

exa-atow:JZ_sw_pytorch rdf:type exa-atow:AIFramework ;
    rdfs:label "PyTorch (Jean Zay)" ;
    exa-atow:softwareName "PyTorch" ;
    exa-atow:moduleCommand "module load pytorch-gpu/py3/<version>" ;
    rdfs:comment "GPU-accelerated PyTorch for CUDA partitions (V100, A100, H100). Module auto-loads CUDA, NCCL, cuDNN, OpenMPI. For A100 partitions, first load arch/a100. For H100, load arch/h100."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_tensorflow rdf:type exa-atow:AIFramework ;
    rdfs:label "TensorFlow (Jean Zay)" ;
    exa-atow:softwareName "TensorFlow" ;
    exa-atow:moduleCommand "module load tensorflow-gpu/py3/<version>" ;
    rdfs:comment "E.g. module load tensorflow-gpu/py3/2.2.0 auto-loads cuda/10.1.2, nccl/2.5.6-2-cuda, cudnn/7.6.5.32-cuda-10.1, intel-compilers/19.0.4, openmpi/4.0.2-cuda."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_conda rdf:type exa-atow:PythonEnvironment ;
    rdfs:label "Anaconda3 / Conda (Jean Zay)" ;
    exa-atow:softwareName "Anaconda3" ;
    exa-atow:moduleCommand "module load anaconda-py3/<version>" ;
    rdfs:comment "idr_module_search utility helps find compatible module combinations for given pip requirements. conda deactivate must be run before module purge."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

# --- Jean Zay: GPU Runtime ---

exa-atow:JZ_sw_cuda rdf:type exa-atow:GPURuntimeLibrary ;
    rdfs:label "CUDA (Jean Zay)" ;
    exa-atow:softwareName "CUDA Toolkit" ;
    exa-atow:moduleCommand "module load cuda/<version>" ;
    rdfs:comment "Loaded automatically as dependency of pytorch-gpu, tensorflow-gpu, etc. Versions available: 10.1.2, 11.x, 12.x depending on partition arch."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_nccl rdf:type exa-atow:CollectiveCommunicationLibrary ;
    rdfs:label "NCCL (Jean Zay)" ;
    exa-atow:softwareName "NVIDIA Collective Communications Library (NCCL)" ;
    exa-atow:moduleCommand "module load nccl/<version>-cuda" ;
    rdfs:comment "GPU-accelerated collective operations (AllReduce, Broadcast…). Loaded automatically by AI framework modules."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

# --- Jean Zay: Profiling / Debugging ---

exa-atow:JZ_sw_arm_forge rdf:type exa-atow:ProfilingTool ;
    rdfs:label "Arm Forge / MAP (Jean Zay)" ;
    exa-atow:softwareName "Arm Forge (MAP + DDT)" ;
    exa-atow:moduleCommand "module load arm-forge" ;
    rdfs:comment "Graphical profiler (MAP) and debugger (DDT) for MPI, OpenMP, CUDA/OpenACC applications. Only usable on frontal (login) nodes. Supports Reverse Connect mode."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_intel_itac rdf:type exa-atow:ProfilingTool ;
    rdfs:label "Intel ITAC (Jean Zay)" ;
    exa-atow:softwareName "Intel Trace Analyzer and Collector (ITAC)" ;
    exa-atow:moduleCommand "module load intel-itac/<version>" ;
    rdfs:comment "MPI trace analysis tool. Versions: 2018.1–2020.2. Compile with -tcollect; visualize with traceanalyzer. Must use same Intel environment for compile, run, and analysis."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_aps rdf:type exa-atow:ProfilingTool ;
    rdfs:label "Intel APS (Jean Zay)" ;
    exa-atow:softwareName "Application Performance Snapshot (APS)" ;
    exa-atow:moduleCommand "module load intel-all/<version>  # includes APS" ;
    rdfs:comment "Lightweight MPI+OpenMP performance profiler. Run via srun aps --collection-mode=mpi,omp ./my_bin. Note: Intel sampling drivers not available on compute nodes."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

# --- Jean Zay: Scientific Libraries ---

exa-atow:JZ_sw_petsc rdf:type exa-atow:ScientificLibrary ;
    rdfs:label "PETSc (Jean Zay)" ;
    exa-atow:softwareName "PETSc — Portable, Extensible Toolkit for Scientific Computation" ;
    exa-atow:moduleCommand "module load intel-compilers/19.1.3 intel-mpi/2019.9 petsc/3.21.4-mpi" ;
    rdfs:comment "Versions: 3.20.x–3.21.x with MPI, complex, int64 variants. Also available with intel-compilers/2021.9.0 + intel-mpi/2021.9. Contact support for additional external libraries."@en ;
    exa-atow:installedOn exa-atow:JeanZay .

exa-atow:JZ_sw_openfoam rdf:type exa-atow:ScientificApplication ;
    rdfs:label "OpenFOAM (Jean Zay)" ;
    exa-atow:softwareName "OpenFOAM" ;
    exa-atow:moduleCommand "module load openfoam/2112-mpi" ;
    exa-atow:installedOn exa-atow:JeanZay .


# ================================================================
# 3. JOLIOT-CURIE / IRÈNE (TGCC/CEA) — SOFTWARE
# ================================================================
# Scheduler: PBS (Bridge/ccc_msub + ccc_mprun).
# Module system: custom TGCC module tree.
# All jobs must declare -m work|scratch|store explicitly.
# ================================================================

# --- Irène: Resource Manager (detail) ---

exa-atow:TGCC_CccMsub rdf:type exa-atow:ResourceManager ;
    rdfs:label "ccc_msub / ccc_mprun (TGCC)" ;
    exa-atow:softwareName "TGCC Bridge/ccc (PBS front-end)" ;
    rdfs:comment "ccc_msub submits jobs (equivalent to qsub). ccc_mprun launches parallel steps (equivalent to mpirun/srun). Interactive: ccc_mprun -s (shell) or ccc_mprun -K (allocation + stay on login node)."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie , exa-atow:Topaze .

# --- Irène: Compilers ---

exa-atow:Irene_sw_gcc rdf:type exa-atow:Compiler ;
    rdfs:label "GCC (Irène)" ;
    exa-atow:softwareName "GNU Compiler Collection" ;
    exa-atow:moduleCommand "module load gnu/<version>" ;
    rdfs:comment "Common versions: 8.3.0, 11.x. Also available as flavor/buildcompiler/gcc/<version> which loads c/gnu, c++/gnu, fortran/gnu together."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_intel rdf:type exa-atow:Compiler ;
    rdfs:label "Intel compilers (Irène)" ;
    exa-atow:softwareName "Intel C/C++/Fortran compilers + MKL" ;
    exa-atow:moduleCommand "module load intel/<version>" ;
    rdfs:comment "Versions: 19.x, 20.0.0, inteloneapi/24.0.0. Loading intel/<version> typically loads c/intel, c++/intel, fortran/intel, and mkl together. Feature modules control MKL mode (e.g. feature/mkl/lp64)."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_nvhpc rdf:type exa-atow:Compiler ;
    rdfs:label "NVHPC / PGI (Irène/Topaze)" ;
    exa-atow:softwareName "NVIDIA HPC SDK (nvhpc)" ;
    exa-atow:moduleCommand "module load nvhpc" ;
    rdfs:comment "Used for OpenACC and CUDA GPU programming. Relevant for the v100l partition. Compile flags: nvfortran -acc=gpu,host -gpu=cc70,cc80."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie , exa-atow:Topaze .

# --- Irène: MPI Libraries ---

exa-atow:Irene_sw_openmpi rdf:type exa-atow:MPILibrary ;
    rdfs:label "OpenMPI (Irène)" ;
    exa-atow:softwareName "Open MPI" ;
    exa-atow:moduleCommand "module load mpi/openmpi/4" ;
    rdfs:comment "OpenMPI available on Irène. Load after compiler, e.g. module load gnu/11 mpi/openmpi/4."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_intel_mpi rdf:type exa-atow:MPILibrary ;
    rdfs:label "Intel MPI (Irène)" ;
    exa-atow:softwareName "Intel MPI Library" ;
    exa-atow:moduleCommand "module load mpi/intelmpi/20.0.4" ;
    rdfs:comment "Versions: 20.0.4, 2021.x (via inteloneapi). Also exposed via feature/intelmpi/mpi_compiler/inteloneapi."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_wi4mpi rdf:type exa-atow:MPILibrary ;
    rdfs:label "Wi4MPI (Irène)" ;
    exa-atow:softwareName "Wi4MPI (Wrapper Interface for MPI)" ;
    exa-atow:moduleCommand "module load feature/wi4mpi/from/openmpi/<version>" ;
    rdfs:comment "CEA-developed MPI compatibility wrapper. Allows switching between OpenMPI-compiled and Intel MPI-compiled executables without recompilation. Source: https://github.com/cea-hpc/wi4mpi."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie , exa-atow:Topaze .

# --- Irène: Math / I/O Libraries ---

exa-atow:Irene_sw_mkl rdf:type exa-atow:MathLibrary ;
    rdfs:label "Intel MKL (Irène)" ;
    exa-atow:softwareName "Intel MKL" ;
    exa-atow:moduleCommand "module load mkl/<version>" ;
    rdfs:comment "Loaded automatically with intel/<version>. Feature modules: feature/mkl/lp64, feature/mkl/sequential, feature/mkl/single_node, feature/mkl/vector/amd."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_hdf5 rdf:type exa-atow:IOLibrary ;
    rdfs:label "HDF5 (Irène)" ;
    exa-atow:softwareName "HDF5" ;
    exa-atow:moduleCommand "module load hdf5/<version>" ;
    rdfs:comment "Version 1.12.0 confirmed in production environment. flavor/hdf5/serial module controls serial vs parallel variant."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_netcdf rdf:type exa-atow:IOLibrary ;
    rdfs:label "NetCDF (Irène)" ;
    exa-atow:softwareName "NetCDF" ;
    exa-atow:moduleCommand "module load netcdf-c/<version>" ;
    rdfs:comment "C and Fortran variants: netcdf-c/4.7.4, netcdf-fortran/4.5.3. Used extensively by climate modeling (LMDZ, NEMO, etc.)."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_python rdf:type exa-atow:PythonEnvironment ;
    rdfs:label "Python3 (Irène)" ;
    exa-atow:softwareName "Python 3" ;
    exa-atow:moduleCommand "module load python3/<version>" ;
    rdfs:comment "Versions: 3.8.10, 3.10.6. Load after compiler+MPI if MPI-aware packages needed, e.g. module load intel/20 mpi/openmpi/4 python3/3.10.6."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_inteloneapi rdf:type exa-atow:Compiler ;
    rdfs:label "Intel oneAPI (Irène)" ;
    exa-atow:softwareName "Intel oneAPI Toolkits" ;
    exa-atow:moduleCommand "module load inteloneapi/<version>" ;
    rdfs:comment "Version 24.0.0 available. Bundles compilers, MPI, MKL, profilers. Use with feature/intelmpi/mpi_compiler/inteloneapi for IntelMPI."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie .

exa-atow:Irene_sw_dmtcp rdf:type exa-atow:CheckpointRestartTool ;
    rdfs:label "DMTCP (Irène/TGCC)" ;
    exa-atow:softwareName "DMTCP (Distributed MultiThreaded Checkpointing)" ;
    exa-atow:moduleCommand "module load dmtcp" ;
    rdfs:comment "Checkpoint-restart tool for long-running jobs. Coordinator daemon launched in job, then dmtcp_launch wraps the application. Restart via dmtcp_restart_script.sh."@en ;
    exa-atow:installedOn exa-atow:JoliotCurie , exa-atow:Topaze .


# ================================================================
# 4. ADASTRA (CINES) — SOFTWARE
# ================================================================
# HPE Cray Programming Environment (CPE). Cray PE uses PrgEnv-* meta-modules.
# Default MPI: cray-mpich (HPE Cray MPICH). Also Cray SHMEM.
# ROCm is the AMD GPU compute stack (HIP, rocBLAS, rocFFT, RCCL, etc.)
# Software stacks: CCE-GPU-*, GCC-GPU-*, CCE-CPU-*, GCC-CPU-*
# ================================================================

# --- Adastra: Programming Environments (meta-modules) ---

exa-atow:Adastra_sw_PrgEnv_cray rdf:type exa-atow:ProgrammingEnvironment ;
    rdfs:label "PrgEnv-cray (Adastra)" ;
    exa-atow:softwareName "Cray Programming Environment — CCE (Cray Compiling Environment)" ;
    exa-atow:moduleCommand "module load PrgEnv-cray" ;
    rdfs:comment "Loads CCE (craycc/crayftn/crayCC) compilers + cray-mpich. craycc supports OpenMP target offload to AMD GPUs. The CCE-GPU-* extensible stacks are built with PrgEnv-cray."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_PrgEnv_gnu rdf:type exa-atow:ProgrammingEnvironment ;
    rdfs:label "PrgEnv-gnu (Adastra)" ;
    exa-atow:softwareName "Cray Programming Environment — GNU" ;
    exa-atow:moduleCommand "module load PrgEnv-gnu" ;
    rdfs:comment "Loads GCC compilers + cray-mpich. Note: GCC does not support Zen4 until v13; for Genoa partition use craype-x86-genoa with GCC >= 13 or use craype-x86-rome. The GCC-GPU-* stacks are built with PrgEnv-gnu."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: CPE versioning ---

exa-atow:Adastra_sw_cpe_2407 rdf:type exa-atow:SoftwareVersion ;
    rdfs:label "CPE 24.07 (Adastra)" ;
    exa-atow:softwareName "Cray Programming Environment" ;
    exa-atow:versionNumber "24.07" ;
    exa-atow:moduleCommand "module load cpe/24.07" ;
    rdfs:comment "Recommended stable CPE release as of 2024. Should be loaded first: module purge && module load cpe/24.07."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: Architecture modules ---

exa-atow:Adastra_sw_craype_gfx90a rdf:type exa-atow:SoftwareVersion ;
    rdfs:label "craype-accel-amd-gfx90a (MI250X target)" ;
    exa-atow:softwareName "Cray PE Architecture Module" ;
    exa-atow:versionNumber "gfx90a" ;
    exa-atow:moduleCommand "module load craype-accel-amd-gfx90a craype-x86-trento" ;
    rdfs:comment "Sets GPU offload target to AMD MI250X (gfx90a) and CPU target to Trento. Required for GPU-aware MPI and HIP compilation on MI250X nodes."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_craype_genoa rdf:type exa-atow:SoftwareVersion ;
    rdfs:label "craype-x86-genoa (Genoa CPU target)" ;
    exa-atow:softwareName "Cray PE Architecture Module" ;
    exa-atow:versionNumber "x86-genoa" ;
    exa-atow:moduleCommand "module load craype-x86-genoa" ;
    rdfs:comment "Sets CPU target to AMD Genoa (Zen4). Note: use craype-x86-rome + GCC >= 13 if encountering Zen4 -march errors with older GCC."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: ROCm ---

exa-atow:Adastra_sw_rocm rdf:type exa-atow:GPURuntimeLibrary ;
    rdfs:label "ROCm (Adastra)" ;
    exa-atow:softwareName "AMD ROCm (Radeon Open Compute platform)" ;
    exa-atow:moduleCommand "module load amd-mixed/<version>" ;
    rdfs:comment "AMD GPU stack: HIP runtime, ROCt/ROCk drivers, rocBLAS, rocFFT, rocSPARSE, MIOpen, RCCL. Key versions: 5.2, 6.0.0, 6.1.2, 6.2.1. Load after PrgEnv-* and craype-accel-amd-gfx90a."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: MPI ---

exa-atow:Adastra_sw_cray_mpich rdf:type exa-atow:MPILibrary ;
    rdfs:label "Cray MPICH (Adastra)" ;
    exa-atow:softwareName "Cray MPICH (HPE Cray MPI)" ;
    exa-atow:moduleCommand "# Loaded automatically with PrgEnv-cray or PrgEnv-gnu" ;
    rdfs:comment "Default MPI on Adastra via HPE Cray PE. GPU-aware MPI support (MPICH_GPU_SUPPORT_ENABLED=1). Note: versions 8.1.28 and 8.1.30 have a known memory leak on MI250X nodes (as of Aug 2025); use 8.1.26."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_rccl rdf:type exa-atow:CollectiveCommunicationLibrary ;
    rdfs:label "RCCL (Adastra)" ;
    exa-atow:softwareName "RCCL — ROCm Collective Communications Library" ;
    rdfs:comment "AMD equivalent of NCCL. Used for GPU-to-GPU collective operations in distributed training on MI250X/MI300A. Part of ROCm stack."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: CINES Extensible Software Stacks ---

exa-atow:Adastra_sw_CCE_GPU rdf:type exa-atow:SoftwareStack ;
    rdfs:label "CCE-GPU extensible stack (Adastra)" ;
    exa-atow:softwareName "CCE-GPU" ;
    exa-atow:moduleCommand "module load CCE-GPU-<version>" ;
    rdfs:comment "CINES extensible software stack built with CCE compilers, targeting GPU partitions (MI250X). Version format: CCE-GPU-X.Y.Z. Exposes domain software (GROMACS, WRF, etc.) with GPU support."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_GCC_GPU rdf:type exa-atow:SoftwareStack ;
    rdfs:label "GCC-GPU extensible stack (Adastra)" ;
    exa-atow:softwareName "GCC-GPU" ;
    exa-atow:moduleCommand "module load GCC-GPU-<version>" ;
    rdfs:comment "CINES extensible software stack built with GCC, targeting GPU partitions. E.g. module load GCC-GPU-3.2.0."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_CCE_CPU rdf:type exa-atow:SoftwareStack ;
    rdfs:label "CCE-CPU extensible stack (Adastra)" ;
    exa-atow:softwareName "CCE-CPU" ;
    exa-atow:moduleCommand "module load CCE-CPU-<version>" ;
    rdfs:comment "CINES extensible software stack for Genoa scalar partition."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_GCC_CPU rdf:type exa-atow:SoftwareStack ;
    rdfs:label "GCC-CPU extensible stack (Adastra)" ;
    exa-atow:softwareName "GCC-CPU" ;
    exa-atow:moduleCommand "module load GCC-CPU-<version>" ;
    rdfs:comment "CINES extensible software stack with GCC for Genoa scalar partition."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: Profiling Tools ---

exa-atow:Adastra_sw_rocprof rdf:type exa-atow:ProfilingTool ;
    rdfs:label "rocprof (Adastra)" ;
    exa-atow:softwareName "ROCm rocprof" ;
    exa-atow:moduleCommand "# Part of ROCm stack (amd-mixed/<version>)" ;
    rdfs:comment "AMD GPU profiler. Use rocprof --stats --timestamp on for kernel statistics. For serialized profiling set AMD_SERIALIZE_COPY=3, AMD_SERIALIZE_KERNEL=3, GPU_MAX_HW_QUEUES=1."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_rocprofiler_compute rdf:type exa-atow:ProfilingTool ;
    rdfs:label "ROCm Compute Profiler / Omniperf (Adastra)" ;
    exa-atow:softwareName "ROCm Compute Profiler (formerly Omniperf)" ;
    rdfs:comment "Low-level AMD GPU kernel profiler for MI100/MI200/MI300. Deeper than rocprof. Use with ROCm >= version used to build the binary."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_cray_pat rdf:type exa-atow:ProfilingTool ;
    rdfs:label "CrayPAT (Adastra)" ;
    exa-atow:softwareName "Cray Performance Analysis Tool (CrayPAT)" ;
    rdfs:comment "Whole-application profiler. Trace groups: mpi, syscall, io, hip, omp. Note: CRAYMPICH+CRAYPAT MPI crash workaround: export PAT_RT_SAMPLING_MODE=bubble."@en ;
    exa-atow:installedOn exa-atow:Adastra .

exa-atow:Adastra_sw_stat rdf:type exa-atow:DebuggingTool ;
    rdfs:label "STAT — Stack Trace Analysis Tool (Adastra)" ;
    exa-atow:softwareName "STAT (Cray Stack Trace Analysis Tool)" ;
    rdfs:comment "Lightweight parallel stack trace collector. Supports MPI, SHMEM, UPC, Fortran Coarrays. No recompilation needed. Compile with DWARF for function names."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: AI / ML Frameworks ---

exa-atow:Adastra_sw_pytorch rdf:type exa-atow:AIFramework ;
    rdfs:label "PyTorch for ROCm (Adastra)" ;
    exa-atow:softwareName "PyTorch (ROCm backend)" ;
    rdfs:comment "Install in a VEnv after loading CPE + PrgEnv-gnu + amd-mixed/6.1.2. Ensure PyTorch ROCm version matches the loaded ROCm. Use RCCL for distributed training."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: Scientific Applications ---

exa-atow:Adastra_sw_gromacs rdf:type exa-atow:ScientificApplication ;
    rdfs:label "GROMACS (Adastra)" ;
    exa-atow:softwareName "GROMACS" ;
    exa-atow:moduleCommand "module load CCE-GPU-2.0.0 && module load gromacs/2023-mpi-omp-plumed-ocl-python3" ;
    rdfs:comment "Multiple versions available: 2021.4, 2022.3, 2022.5, 2023, 2023.3, 2024.3. Variants: mpi-omp-plumed, cp2k, ocl. GPU offload via OpenCL (-ocl) or HIP."@en ;
    exa-atow:installedOn exa-atow:Adastra .

# --- Adastra: Spack ---

exa-atow:Adastra_sw_spack_user rdf:type exa-atow:PackageManager ;
    rdfs:label "Spack user (PreConf) — Adastra" ;
    exa-atow:softwareName "Spack PreConf (CINES pre-configured)" ;
    exa-atow:moduleCommand "module load spack-user-<version>" ;
    rdfs:comment "CINES pre-configured Spack instance. Reuses CINES compiler toolchains and binary cache. Partition-specific: use zen3 modules for MI250X, zen4 for Genoa. Preconfigured compilers: GCC@13.2.0, rocmcc@6.1.2 (Trento), rocmcc@6.1.2.genoa (Genoa)."@en ;
    exa-atow:installedOn exa-atow:Adastra .


# ================================================================
# 5. CROSS-CENTER: LINK SOFTWARE TO SYSTEMS
# ================================================================
# Explicit exa-atow:installedOn triples consolidate which software
# is confirmed on which machine. Already stated inline above.
# Additional cross-center aliases for query convenience:
# ================================================================

# Jean Zay uses SLURM
exa-atow:JeanZay exa-atow:usesResourceManager exa-atow:SLURM .

# Irène / Topaze use PBS (Bridge/ccc)
exa-atow:JoliotCurie exa-atow:usesResourceManager exa-atow:TGCC_CccMsub .
exa-atow:Topaze     exa-atow:usesResourceManager exa-atow:TGCC_CccMsub .

# Adastra uses SLURM
exa-atow:Adastra exa-atow:usesResourceManager exa-atow:SLURM .

# Jean Zay supports compilers
exa-atow:JeanZay exa-atow:supportsCompiler exa-atow:JZ_sw_gcc ,
                                            exa-atow:JZ_sw_intel_compilers ,
                                            exa-atow:JZ_sw_pgi .

exa-atow:JeanZay exa-atow:supportsMPI exa-atow:JZ_sw_openmpi ,
                                      exa-atow:JZ_sw_intel_mpi .

# Irène supports compilers
exa-atow:JoliotCurie exa-atow:supportsCompiler exa-atow:Irene_sw_gcc ,
                                               exa-atow:Irene_sw_intel ,
                                               exa-atow:Irene_sw_nvhpc ,
                                               exa-atow:Irene_sw_inteloneapi .

exa-atow:JoliotCurie exa-atow:supportsMPI exa-atow:Irene_sw_openmpi ,
                                          exa-atow:Irene_sw_intel_mpi ,
                                          exa-atow:Irene_sw_wi4mpi .

# Adastra supports compilers (via Cray PE)
exa-atow:Adastra exa-atow:supportsCompiler exa-atow:Adastra_sw_PrgEnv_cray ,
                                           exa-atow:Adastra_sw_PrgEnv_gnu .

exa-atow:Adastra exa-atow:supportsMPI exa-atow:Adastra_sw_cray_mpich .

exa-atow:Adastra exa-atow:supportsGPUStack exa-atow:Adastra_sw_rocm .
exa-atow:JeanZay exa-atow:supportsGPUStack exa-atow:JZ_sw_cuda .
