                 "720 nœuds scalaires CPU (après décommissionnement de 808 nœuds le 05/02/2024). 2×Intel Xeon Gold 6248, 40 cœurs, 192 Go RAM. Interconnexion OPA 100 Gb/s, 1 lien/nœud."@fr ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 192 ;
    exa-atow:linkCount 1 ;
    exa-atow:connectedVia inst:IC_IntelOPA_100G ;
    exa-atow:equippedWith inst:CPU_IntelXeonGold6248 ;
    exa-atow:runsOS inst:OS_RHEL94 .

