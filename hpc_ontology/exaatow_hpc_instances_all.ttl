###############################################################################
# Exa-AToW HPC Resource Ontology – INSTANCES
# French National HPC Centers: Jean Zay (IDRIS), Irene (TGCC/CEA), Adastra (CINES)
#
# Version     : 1.0
# Date        : 2026-02-18
# Sources     :
#   - http://www.idris.fr/docs/jean-zay/jean-zay/jean-zay-hardware/
#   - https://hpc.cea.fr/tgcc-public/en/html/toc/fulldoc/Supercomputer_architecture.html
#   - https://dci.dci-gitlab.cines.fr/webextranet/architecture/index.html
#   - https://www.cines.fr/calcul/adastra/
#
# - Alice Recoque
#   - GPU Partition - 94 cabinets :
#     1 CPU AMD Venice 256 cores, 8Gb RAM
#     4 GPUs AMD MI430X 432Gb HBM4, 19.6To/s (bande passante de memoire)
#     1 Tb MRDIMM 4Gb/core
#     2x400 Gbs BULL BXIv3 / GPU
#     1x 400 Gbs BULLBXIv3 / CPU
#
#   - CPU Partition - 10 cabinets :
#     10k cores SiPearl Rhea2
#
#   - Visio Partition :
#     34 nodes
#
# Authors     : Exa-AToW team
#
# Notes       :
#   EN – This file contains individuals (instances) for the three main French
#        national HPC centers managed by GENCI. Data reflect the state of the
#        systems as documented in early 2026.
#   FR – Ce fichier contient les individus (instances) pour les trois
#        principaux centres nationaux de calcul intensif français gérés par
#        GENCI. Les données reflètent l'état des systèmes documenté début 2026.
###############################################################################

@prefix exa-atow: <https://cnherrera.github.io/Exa-AToW_onto/hpc_ontology/exaatow_hpc_ontology.ttl#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:       <http://purl.org/dc/elements/1.1/> .
@prefix inst:     <https://cnherrera.github.io/Exa-AToW_onto/hpc_ontology/exaatow_hpc_instances.ttl#> .

<https://cnherrera.github.io/Exa-AToW_onto/hpc_ontology/exaatow_hpc_instances.ttl>
    rdf:type owl:Ontology ;
    owl:imports <https://cnherrera.github.io/Exa-AToW_onto/hpc_ontology/exaatow_hpc_ontology.ttl> ;
    rdfs:label "Exa-AToW HPC Instances – French National HPC Centers"@en ,
               "Exa-AToW Instances HPC – Centres nationaux de calcul français"@fr ;
    dc:description "Instances of French national HPC centers (Jean Zay, Irene/TGCC, Adastra) with their hardware, partitions, storage, and software."@en ;
    owl:versionInfo "1.0" .


###############################################################################
# ══════════════════════════════════════════════════════════════════════════════
# SECTION 1 – ORGANIZATIONS / ORGANISATIONS
# ══════════════════════════════════════════════════════════════════════════════
# EN – Institutions that operate and fund the French national HPC centers.
# FR – Institutions qui exploitent et financent les centres nationaux de calcul.
###############################################################################

inst:Org_IDRIS rdf:type exa-atow:Organization ;
    rdfs:label "IDRIS"@en , "IDRIS"@fr ;
    rdfs:comment "Institut du Développement et des Ressources en Informatique Scientifique. HPC division of CNRS, operator of Jean Zay."@en ,
                 "Institut du Développement et des Ressources en Informatique Scientifique. Division HPC du CNRS, opérateur de Jean Zay."@fr ;
    exa-atow:shortName "idris" ;
    exa-atow:website "https://www.idris.fr"^^xsd:anyURI .

inst:Org_CNRS rdf:type exa-atow:Organization ;
    rdfs:label "CNRS"@en , "CNRS"@fr ;
    rdfs:comment "Centre National de la Recherche Scientifique – parent body of IDRIS."@en ,
                 "Centre National de la Recherche Scientifique – organisme de tutelle de l'IDRIS."@fr ;
    exa-atow:shortName "cnrs" ;
    exa-atow:website "https://www.cnrs.fr"^^xsd:anyURI .

inst:Org_CEA rdf:type exa-atow:Organization ;
    rdfs:label "CEA"@en , "CEA"@fr ;
    rdfs:comment "Commissariat à l'Énergie Atomique et aux Énergies Alternatives. Operates TGCC."@en ,
                 "Commissariat à l'Énergie Atomique et aux Énergies Alternatives. Opérateur du TGCC."@fr ;
    exa-atow:shortName "cea" ;
    exa-atow:website "https://www.cea.fr"^^xsd:anyURI .

inst:Org_CINES rdf:type exa-atow:Organization ;
    rdfs:label "CINES"@en , "CINES"@fr ;
    rdfs:comment "Centre Informatique National de l'Enseignement Supérieur. Operates Adastra in Montpellier."@en ,
                 "Centre Informatique National de l'Enseignement Supérieur. Opérateur d'Adastra à Montpellier."@fr ;
    exa-atow:shortName "cines" ;
    exa-atow:website "https://www.cines.fr"^^xsd:anyURI .

inst:Org_GENCI rdf:type exa-atow:FundingAgency ;
    rdfs:label "GENCI"@en , "GENCI"@fr ;
    rdfs:comment "Grand Équipement National de Calcul Intensif. National agency that funds and coordinates HPC access in France."@en ,
                 "Grand Équipement National de Calcul Intensif. Agence nationale qui finance et coordonne l'accès au calcul intensif en France."@fr ;
    exa-atow:shortName "genci" ;
    exa-atow:website "https://www.genci.fr"^^xsd:anyURI .

inst:Org_France2030 rdf:type exa-atow:FundingAgency ;
    rdfs:label "France 2030"@en , "France 2030"@fr ;
    rdfs:comment "French government investment plan that co-funded the Jean Zay H100 extension (gpu_p6)."@en ,
                 "Plan d'investissement du gouvernement français qui a cofinancé l'extension H100 de Jean Zay (gpu_p6)."@fr ;
    exa-atow:shortName "france2030" .


###############################################################################
# ══════════════════════════════════════════════════════════════════════════════
# SECTION 2 – HPC CENTERS / CENTRES HPC
# ══════════════════════════════════════════════════════════════════════════════
# EN – The three main French national HPC centers.
# FR – Les trois principaux centres nationaux de calcul intensif français.
###############################################################################

inst:Center_IDRIS rdf:type exa-atow:HPCCenter ;
    rdfs:label "IDRIS HPC Center"@en , "Centre HPC IDRIS"@fr ;
    rdfs:comment "IDRIS, located in Orsay (Essonne), houses the Jean Zay supercomputer. Managed by CNRS."@en ,
                 "L'IDRIS, situé à Orsay (Essonne), héberge le supercalculateur Jean Zay. Géré par le CNRS."@fr ;
    exa-atow:shortName "idris" ;
    exa-atow:location "Orsay, Essonne, France" ;
    exa-atow:website "https://www.idris.fr"^^xsd:anyURI ;
    exa-atow:documentationURL "https://www.idris.fr/eng/jean-zay/"^^xsd:anyURI ;
    exa-atow:operatedBy inst:Org_IDRIS ;
    exa-atow:hosts inst:SC_JeanZay ;
    exa-atow:hasStorageMount inst:Mount_JZ_HOME ,
                             inst:Mount_JZ_WORK ,
                             inst:Mount_JZ_SCRATCH ,
                             inst:Mount_JZ_STORE .

inst:Center_TGCC rdf:type exa-atow:HPCCenter ;
    rdfs:label "TGCC – Très Grand Centre de Calcul"@en , "TGCC – Très Grand Centre de Calcul"@fr ;
    rdfs:comment "TGCC (Very Large Computing Center) in Bruyères-le-Châtel (Essonne), operated by CEA/DAM. Hosts Irene (Joliot-Curie) for academic research and Topaze for industrial R&D (CCRT)."@en ,
                 "Le TGCC (Très Grand Centre de Calcul) à Bruyères-le-Châtel (Essonne), opéré par la CEA/DAM. Héberge Irène (Joliot-Curie) pour la recherche académique et Topaze pour la R&D industrielle (CCRT)."@fr ;
    exa-atow:shortName "tgcc" ;
    exa-atow:location "Bruyères-le-Châtel, Essonne, France" ;
    exa-atow:website "https://www-hpc.cea.fr/en/TGCC.html"^^xsd:anyURI ;
    exa-atow:documentationURL "https://hpc.cea.fr/tgcc-public/en/html/toc/fulldoc/Supercomputer_architecture.html"^^xsd:anyURI ;
    exa-atow:operatedBy inst:Org_CEA ;
    exa-atow:hosts inst:SC_Irene , inst:SC_Topaze ;
    exa-atow:hasStorageMount inst:Mount_Irene_HOME ,
                             inst:Mount_Irene_SCRATCH ,
                             inst:Mount_Irene_STORE .

inst:Center_CINES rdf:type exa-atow:HPCCenter ;
    rdfs:label "CINES HPC Center"@en , "Centre HPC CINES"@fr ;
    rdfs:comment "CINES in Montpellier (Hérault) houses the Adastra supercomputer, an HPE Cray EX system with AMD processors and AMD Instinct GPUs."@en ,
                 "Le CINES à Montpellier (Hérault) héberge le supercalculateur Adastra, un système HPE Cray EX avec des processeurs AMD et des GPU AMD Instinct."@fr ;
    exa-atow:shortName "cines" ;
    exa-atow:location "Montpellier, Hérault, France" ;
    exa-atow:website "https://www.cines.fr"^^xsd:anyURI ;
    exa-atow:documentationURL "https://www.cines.fr/calcul/adastra/"^^xsd:anyURI ;
    exa-atow:operatedBy inst:Org_CINES ;
    exa-atow:hosts inst:SC_Adastra ;
    exa-atow:hasStorageMount inst:Mount_Adastra_HOME ,
                             inst:Mount_Adastra_SCRATCH .


###############################################################################
# ══════════════════════════════════════════════════════════════════════════════
# SECTION 3 – SUPERCOMPUTERS / SUPERCALCULATEURS
# ══════════════════════════════════════════════════════════════════════════════
###############################################################################

# ─────────────────────────────────────────────────────────────────────────────
# 3A – JEAN ZAY (IDRIS / CNRS)
# ─────────────────────────────────────────────────────────────────────────────
# EN – Jean Zay is a hybrid supercomputer made of an HPE SGI 8600 part and an
#      Eviden BullSequana XH3000 part. After three extensions, its cumulated
#      peak performance reached 125.9 PFlop/s in July 2024. It uses SLURM as
#      job scheduler and a Lustre parallel file system.
# FR – Jean Zay est un supercalculateur hybride composé d'une partie HPE SGI 8600
#      et d'une partie Eviden BullSequana XH3000. Après trois extensions
#      successives, sa puissance crête cumulée a atteint 125,9 PFlop/s en
#      juillet 2024. Il utilise SLURM comme gestionnaire de ressources et un
#      système de fichiers parallèle Lustre.

inst:SC_JeanZay rdf:type exa-atow:Supercomputer ;
    rdfs:label "Jean Zay"@en , "Jean Zay"@fr ;
    rdfs:comment "Hybrid supercomputer at IDRIS. HPE SGI 8600 part + Eviden BullSequana XH3000 part. 125.9 PFlop/s peak (since July 2024). Main resource for French AI and HPC research."@en ,
                 "Supercalculateur hybride à l'IDRIS. Partie HPE SGI 8600 + partie Eviden BullSequana XH3000. 125,9 PFlop/s crête depuis juillet 2024. Principale ressource pour la recherche IA et HPC française."@fr ;
    exa-atow:shortName "jean-zay" ;
    exa-atow:identifier "jean-zay.idris.fr" ;
    exa-atow:commissioningDate "2019-06-01"^^xsd:date ;
    exa-atow:documentationURL "https://www.idris.fr/eng/jean-zay/"^^xsd:anyURI ;
    exa-atow:usesResourceManager exa-atow:SLURM ;
    exa-atow:runsOS inst:OS_RHEL94 ;
    exa-atow:usesFileSystem inst:FS_JZ_Lustre ;
    exa-atow:fundedBy inst:Org_GENCI , inst:Org_France2030 ;
    exa-atow:supportsCompiler exa-atow:IntelCompiler , exa-atow:GCC , exa-atow:NVCC , exa-atow:AOCC ;
    exa-atow:hasGeneration inst:Gen_JZ_SGI8600 , inst:Gen_JZ_BullSequana ;
    exa-atow:hasPartition inst:Part_JZ_cpu_p1 ,
                           inst:Part_JZ_gpu_p13 ,
                           inst:Part_JZ_gpu_p2 ,
                           inst:Part_JZ_gpu_p5 ,
                           inst:Part_JZ_gpu_p6 ,
                           inst:Part_JZ_prepost ,
                           inst:Part_JZ_visu ,
                           inst:Part_JZ_compil ,
                           inst:Part_JZ_compil_h100 ,
                           inst:Part_JZ_archive ;
    exa-atow:hasFrontendNodes inst:Node_JZ_Frontend ;
    exa-atow:hasPeakPerformance inst:Perf_JZ_125PFlops ;
    exa-atow:nodeCount 1612 .

# Hardware generations / Générations matérielles
inst:Gen_JZ_SGI8600 rdf:type exa-atow:HardwareGeneration ;
    rdfs:label "Jean Zay – HPE SGI 8600 (original)"@en ,
               "Jean Zay – HPE SGI 8600 (original)"@fr ;
    rdfs:comment "Original HPE SGI 8600 installation: CPU nodes + V100 GPU nodes, interconnected via Intel Omni-Path 100 Gb/s."@en ,
                 "Installation originale HPE SGI 8600 : nœuds CPU + nœuds GPU V100, interconnectés via Intel Omni-Path 100 Gb/s."@fr ;
    exa-atow:commissioningDate "2019-06-01"^^xsd:date .

inst:Gen_JZ_BullSequana rdf:type exa-atow:HardwareGeneration ;
    rdfs:label "Jean Zay – Eviden BullSequana XH3000 (H100 extension)"@en ,
               "Jean Zay – Eviden BullSequana XH3000 (extension H100)"@fr ;
    rdfs:comment "H100 extension by Eviden (summer 2024): 364 nodes × 4 H100 SXM5 80GB, InfiniBand NDR 400 Gb/s. Co-funded by France 2030."@en ,
                 "Extension H100 par Eviden (été 2024) : 364 nœuds × 4 H100 SXM5 80 Go, InfiniBand NDR 400 Gb/s. Cofinancée par France 2030."@fr ;
    exa-atow:commissioningDate "2024-07-01"^^xsd:date .

# ─────────────────────────────────────────────────────────────────────────────
# 3B – IRENE / JOLIOT-CURIE (TGCC / CEA)
# ─────────────────────────────────────────────────────────────────────────────
# EN – Irene (also called Joliot-Curie) is the academic supercomputer at TGCC.
#      It is a BullSequana XH2000 / XH2000 AMD system. The main partition
#      "Rome" has 2286 AMD Rome nodes. Scheduler is PBS Professional.
# FR – Irène (aussi appelée Joliot-Curie) est le supercalculateur académique
#      du TGCC. Il s'agit d'un système BullSequana XH2000 / AMD. La partition
#      principale "Rome" dispose de 2286 nœuds AMD Rome. L'ordonnanceur est PBS.

inst:SC_Irene rdf:type exa-atow:Supercomputer ;
    rdfs:label "Irene (Joliot-Curie)"@en , "Irène (Joliot-Curie)"@fr ;
    rdfs:comment "Academic supercomputer at TGCC. BullSequana XH2000 system with AMD Rome, Intel Skylake, and NVIDIA V100 GPU nodes. Operated by CEA/DAM for GENCI/PRACE users. Scheduler: PBS Professional. ~22 PFlop/s peak."@en ,
                 "Supercalculateur académique du TGCC. Système BullSequana XH2000 avec nœuds AMD Rome, Intel Skylake et GPU NVIDIA V100. Opéré par CEA/DAM pour les utilisateurs GENCI/PRACE. Ordonnanceur : PBS Professional. ~22 PFlop/s crête."@fr ;
    exa-atow:shortName "irene" ;
    exa-atow:identifier "irene.ccc.cea.fr" ;
    exa-atow:commissioningDate "2019-01-01"^^xsd:date ;
    exa-atow:documentationURL "https://hpc.cea.fr/tgcc-public/en/html/toc/fulldoc/Supercomputer_architecture.html"^^xsd:anyURI ;
    exa-atow:usesResourceManager exa-atow:PBS ;
    exa-atow:runsOS inst:OS_RHEL ;
    exa-atow:usesFileSystem inst:FS_Irene_Lustre ;
    exa-atow:fundedBy inst:Org_GENCI ;
    exa-atow:supportsCompiler exa-atow:IntelCompiler , exa-atow:GCC , exa-atow:AOCC , exa-atow:CrayCC ;
    exa-atow:hasPartition inst:Part_Irene_rome ,
                           inst:Part_Irene_v100 ,
                           inst:Part_Irene_xlarge ;
    exa-atow:hasFrontendNodes inst:Node_Irene_Frontend ;
    exa-atow:hasPeakPerformance inst:Perf_Irene_22PFlops ;
    exa-atow:nodeCount 2355 .

# ─────────────────────────────────────────────────────────────────────────────
# 3C – TOPAZE (TGCC / CCRT, industrial)
# ─────────────────────────────────────────────────────────────────────────────
# EN – Topaze is the industrial HPC machine at TGCC (CCRT), not accessible to
#      general academic researchers. It uses AMD Milan processors and Nvidia
#      A100 GPUs. ~12.4 PFlop/s.
# FR – Topaze est la machine HPC industrielle du TGCC (CCRT), non accessible
#      aux chercheurs académiques généraux. Processeurs AMD Milan, GPU Nvidia
#      A100. ~12,4 PFlop/s.

inst:SC_Topaze rdf:type exa-atow:Supercomputer ;
    rdfs:label "Topaze (CCRT)"@en , "Topaze (CCRT)"@fr ;
    rdfs:comment "Industrial HPC supercomputer at CCRT/TGCC. AMD EPYC Milan 64-core nodes + 48 GPU nodes (A100). Accessible to CEA laboratories and industrial partners, not open academic research."@en ,
                 "Supercalculateur HPC industriel au CCRT/TGCC. Nœuds AMD EPYC Milan 64 cœurs + 48 nœuds GPU (A100). Accessible aux laboratoires CEA et partenaires industriels, pas à la recherche académique ouverte."@fr ;
    exa-atow:shortName "topaze" ;
    exa-atow:identifier "topaze.ccc.cea.fr" ;
    exa-atow:commissioningDate "2021-06-01"^^xsd:date ;
    exa-atow:documentationURL "https://www-hpc.cea.fr/en/TGCC.html"^^xsd:anyURI ;
    exa-atow:usesResourceManager exa-atow:PBS ;
    exa-atow:usesFileSystem inst:FS_Topaze_Lustre ;
    exa-atow:fundedBy inst:Org_CEA ;
    exa-atow:hasPartition inst:Part_Topaze_milan ,
                          inst:Part_Topaze_gpu ;
    exa-atow:nodeCount 912 .

# ─────────────────────────────────────────────────────────────────────────────
# 3D – ADASTRA (CINES)
# ─────────────────────────────────────────────────────────────────────────────
# EN – Adastra is an HPE Cray EX4000 system at CINES, Montpellier. Two main
#      compute partitions: scalar nodes (AMD Genoa EPYC 9654) and accelerated
#      nodes (AMD EPYC Trento + AMD Instinct MI250X). Extended in 2024 with
#      AMD MI300A APU nodes (Adastra2). ~74 PFlop/s total. Scheduler: SLURM.
# FR – Adastra est un système HPE Cray EX4000 au CINES à Montpellier. Deux
#      partitions de calcul : nœuds scalaires (AMD Genoa EPYC 9654) et nœuds
#      accélérés (AMD EPYC Trento + AMD Instinct MI250X). Étendu en 2024 avec
#      des nœuds APU AMD MI300A (Adastra2). ~74 PFlop/s total. Ordonnanceur : SLURM.

inst:SC_Adastra rdf:type exa-atow:Supercomputer ;
    rdfs:label "Adastra"@en , "Adastra"@fr ;
    rdfs:comment "HPE Cray EX4000 supercomputer at CINES. Scalar partition (AMD Genoa) + accelerated partition (AMD Trento + MI250X) + APU partition (Adastra2/MI300A). Direct liquid cooling (DLC). ~74 PFlop/s peak total. Ranked 3rd on Green500 in 2022."@en ,
                 "Supercalculateur HPE Cray EX4000 au CINES. Partition scalaire (AMD Genoa) + partition accélérée (AMD Trento + MI250X) + partition APU (Adastra2/MI300A). Refroidissement liquide direct (DLC). ~74 PFlop/s crête totale. Classé 3e au Green500 en 2022."@fr ;
    exa-atow:shortName "adastra" ;
    exa-atow:identifier "adastra.cines.fr" ;
    exa-atow:commissioningDate "2022-09-01"^^xsd:date ;
    exa-atow:documentationURL "https://www.cines.fr/calcul/adastra/"^^xsd:anyURI ;
    exa-atow:usesResourceManager exa-atow:SLURM ;
    exa-atow:runsOS inst:OS_RHEL88 ;
    exa-atow:usesFileSystem inst:FS_Adastra_Lustre ;
    exa-atow:fundedBy inst:Org_GENCI ;
    exa-atow:supportsCompiler exa-atow:GCC , exa-atow:AOCC , exa-atow:CrayCC ;
    exa-atow:hasGeneration inst:Gen_Adastra1 , inst:Gen_Adastra2 ;
    exa-atow:hasPartition inst:Part_Adastra_scalar ,
                           inst:Part_Adastra_gpu ,
                           inst:Part_Adastra_apu ,
                           inst:Part_Adastra_visu ;
    exa-atow:hasFrontendNodes inst:Node_Adastra_Frontend ;
    exa-atow:hasPeakPerformance inst:Perf_Adastra_74PFlops ;
    exa-atow:nodeCount 928 .

inst:Gen_Adastra1 rdf:type exa-atow:HardwareGeneration ;
    rdfs:label "Adastra 1 – MI250X partition (2022)"@en ,
               "Adastra 1 – Partition MI250X (2022)"@fr ;
    rdfs:comment "Original Adastra installation: 356 accelerated nodes (AMD Trento + 4×MI250X) + 544 scalar nodes (AMD Genoa)."@en ,
                 "Installation originale d'Adastra : 356 nœuds accélérés (AMD Trento + 4×MI250X) + 544 nœuds scalaires (AMD Genoa)."@fr ;
    exa-atow:commissioningDate "2022-09-01"^^xsd:date .

inst:Gen_Adastra2 rdf:type exa-atow:HardwareGeneration ;
    rdfs:label "Adastra 2 – MI300A APU extension (2024)"@en ,
               "Adastra 2 – Extension APU MI300A (2024)"@fr ;
    rdfs:comment "Extension with 28 AMD MI300A APU nodes (unified CPU+GPU memory). Ranked 3rd Green500 November 2024."@en ,
                 "Extension avec 28 nœuds APU AMD MI300A (mémoire CPU+GPU unifiée). Classé 3e Green500 novembre 2024."@fr ;
    exa-atow:commissioningDate "2024-06-01"^^xsd:date .


###############################################################################
# ══════════════════════════════════════════════════════════════════════════════
# SECTION 4 – PROCESSORS / PROCESSEURS
# ══════════════════════════════════════════════════════════════════════════════
# EN – CPU and GPU processor specifications referenced by compute nodes.
# FR – Spécifications des processeurs CPU et GPU référencés par les nœuds de calcul.
###############################################################################

# ────────── CPUs ──────────────────────────────────────────────────────────────

inst:CPU_IntelXeonGold6248 rdf:type exa-atow:CPU ;
    rdfs:label "Intel Xeon Gold 6248"@en ;
    rdfs:comment "20-core Intel Cascade Lake CPU at 2.5 GHz. Used in Jean Zay cpu_p1 and V100 gpu_p13 nodes."@en ,
                 "CPU Intel Cascade Lake 20 cœurs à 2,5 GHz. Utilisé dans les nœuds cpu_p1 et V100 gpu_p13 de Jean Zay."@fr ;
    exa-atow:vendor "Intel" ;
    exa-atow:model "Intel Xeon Gold 6248" ;
    exa-atow:architecture "Cascade Lake" ;
    exa-atow:coreCount 20 ;
    exa-atow:hasFrequency inst:Freq_2_5GHz .

inst:CPU_IntelXeonGold6226 rdf:type exa-atow:CPU ;
    rdfs:label "Intel Xeon Gold 6226"@en ;
    rdfs:comment "12-core Intel Cascade Lake CPU at 2.7 GHz. Used in Jean Zay gpu_p2 (8-GPU V100) nodes."@en ,
                 "CPU Intel Cascade Lake 12 cœurs à 2,7 GHz. Utilisé dans les nœuds gpu_p2 (8-GPU V100) de Jean Zay."@fr ;
    exa-atow:vendor "Intel" ;
    exa-atow:model "Intel Xeon Gold 6226" ;
    exa-atow:architecture "Cascade Lake" ;
    exa-atow:coreCount 12 ;
    exa-atow:hasFrequency inst:Freq_2_7GHz .

inst:CPU_AMDMilanEPYC7543 rdf:type exa-atow:CPU ;
    rdfs:label "AMD EPYC 7543 (Milan)"@en ;
    rdfs:comment "32-core AMD Milan CPU at 2.80 GHz. Used in Jean Zay gpu_p5 (A100) nodes. Requires arch/a100 module."@en ,
                 "CPU AMD Milan 32 cœurs à 2,80 GHz. Utilisé dans les nœuds gpu_p5 (A100) de Jean Zay. Nécessite le module arch/a100."@fr ;
    exa-atow:vendor "AMD" ;
    exa-atow:model "AMD EPYC 7543" ;
    exa-atow:architecture "Milan" ;
    exa-atow:coreCount 32 ;
    exa-atow:hasFrequency inst:Freq_2_8GHz .

