# the scalar node has 2 AMD EPYC9654 CPUs per node.
inst:Node_Adastra_Scalar rdf:type exa-atow:ScalarNode ;
    rdfs:label "Adastra – scalar node type (AMD Genoa)"@en ,
               "Adastra – Type nœud scalaire (AMD Genoa)"@fr ;
    rdfs:comment "544 scalar nodes. 2×AMD Genoa EPYC 9654 (192 cores/node), 768 GB DDR5-5200, 1×Slingshot 200 Gb/s NIC."@en ,
                 "544 nœuds scalaires. 2×AMD Genoa EPYC 9654 (192 cœurs/nœud), 768 Go DDR5-5200, 1×NIC Slingshot 200 Gb/s."@fr ;
