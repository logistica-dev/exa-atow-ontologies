    rdfs:label "Adastra – visualization/prepost node type"@en ,
               "Adastra – Type nœud visualisation/pré-post"@fr ;
    rdfs:comment "12 visualization and pre/post-processing nodes. 2×AMD Genoa 64-core, 2×NVIDIA L40 GPUs."@en ,
                 "12 nœuds de visualisation et pré/post-traitement. 2×AMD Genoa 64 cœurs, 2×GPU NVIDIA L40."@fr ;
