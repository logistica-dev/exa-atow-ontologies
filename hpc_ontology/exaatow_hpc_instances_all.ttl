# ──── Jean Zay: Lustre ────────────────────────────────────────────────────────
inst:FS_JZ_Lustre rdf:type exa-atow:Lustre ;
    rdfs:label "Jean Zay – Lustre parallel file system"@en ,
               "Jean Zay – Système de fichiers parallèle Lustre"@fr ;
    rdfs:comment "Lustre file system on Jean Zay: 2.5 PB SSD (GridScaler GS18K SSD, fast I/O) + >30 PB HDD capacity."@en ,
                 "Système de fichiers Lustre de Jean Zay : 2,5 Po SSD (GridScaler GS18K SSD, E/S rapides) + >30 Po de capacité HDD."@fr .

inst:Mount_JZ_HOME rdf:type exa-atow:StorageMount ;
    rdfs:label "Jean Zay – $HOME"@en , "Jean Zay – $HOME"@fr ;
    rdfs:comment "Personal home space. Small quota, backed up. Persistent."@en ,
                 "Espace personnel. Petit quota, sauvegardé. Persistant."@fr ;
    exa-atow:mountPath "$HOME" ;
    exa-atow:isPurged false ;
    exa-atow:mountedOn inst:FS_JZ_Lustre .

inst:Mount_JZ_WORK rdf:type exa-atow:StorageMount ;
    rdfs:label "Jean Zay – $WORK"@en , "Jean Zay – $WORK"@fr ;
    rdfs:comment "Working space for active computations. Accessible from all partitions. Not backed up."@en ,
                 "Espace de travail pour les calculs en cours. Accessible depuis toutes les partitions. Non sauvegardé."@fr ;
    exa-atow:mountPath "$WORK" ;
    exa-atow:isPurged false ;
    exa-atow:mountedOn inst:FS_JZ_Lustre .

inst:Mount_JZ_SCRATCH rdf:type exa-atow:StorageMount ;
    rdfs:label "Jean Zay – $SCRATCH"@en , "Jean Zay – $SCRATCH"@fr ;
    rdfs:comment "Temporary scratch space on fast SSD Lustre. Accessible from compute nodes. Large capacity, not backed up, purged automatically after inactivity."@en ,
                 "Espace scratch temporaire sur Lustre SSD rapide. Accessible depuis les nœuds de calcul. Grande capacité, non sauvegardé, purgé automatiquement après inactivité."@fr ;
    exa-atow:mountPath "$SCRATCH" ;
    exa-atow:isPurged true ;
    exa-atow:mountedOn inst:FS_JZ_Lustre .

inst:Mount_JZ_STORE rdf:type exa-atow:StorageMount ;
    rdfs:label "Jean Zay – $STORE"@en , "Jean Zay – $STORE"@fr ;
    rdfs:comment "Permanent archive/long-term storage. Max file size 10 TiB. Only accessible from login nodes and prepost/archive/compil/visu partitions (not from compute nodes since July 2024)."@en ,
                 "Stockage archive/long terme permanent. Taille max par fichier 10 Tio. Accessible uniquement depuis les nœuds de connexion et les partitions prepost/archive/compil/visu (pas depuis les nœuds de calcul depuis juillet 2024)."@fr ;
    exa-atow:mountPath "$STORE" ;
    exa-atow:isPurged false ;
    exa-atow:mountedOn inst:FS_JZ_Lustre .

