    exa-atow:ramPerNode 768 ;
    exa-atow:linkCount 1 ;
    exa-atow:connectedVia inst:IC_SlingShot_200G ;
    exa-atow:equippedWith inst:CPU_AMDGenoaEPYC9654 ;
    exa-atow:cpuCorePerNode 192 ;
    # TDP per scalar node: 945 W
    exa-atow:hasTDP [
        exa-atow:hasValue 945 ;
        exa-atow:hasUnit "W"
    ] .

# ──── Adastra: accelerated (MI250X) node ──────────────────────────────────────
inst:Node_Adastra_GPU rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Adastra – accelerated MI250X node type"@en ,
               "Adastra – Type nœud accéléré MI250X"@fr ;
    rdfs:comment "356 accelerated nodes (HPE Cray EX235a blade). 1×AMD EPYC 7A53 Trento (64 cores), 256 GB DDR4, 4×AMD Instinct MI250X. Each card has its own Slingshot NIC, 4×200 Gb/s = 800 Gb/s total injection bandwidth."@en ,
                 "356 nœuds accélérés (lame HPE Cray EX235a). 1×AMD EPYC 7A53 Trento (64 cœurs), 256 Go DDR4, 4×AMD Instinct MI250X. Chaque carte a son propre NIC Slingshot, 4×200 Gb/s = 800 Gb/s de bande passante d'injection totale."@fr ;
    exa-atow:equippedWith inst:CPU_AMD_EPYC7A53_Trento ;		 
    exa-atow:socketCount 1 ;
    exa-atow:cpuCorePerNode 64 ;
    exa-atow:ramPerNode 256 ;
    exa-atow:ramModel "DDR4-3200" ;
    # 8 GCDs visible to runtime (4 cards x 2 GCDs)
    exa-atow:gpuCount 8 ;    
    exa-atow:linkCount 4 ;
    exa-atow:connectedVia inst:IC_SlingShot_200G ;
    exa-atow:hasAcceleratorCard inst:Card_MI250X ;
    # TDP per accelerated node: 2670 W
    exa-atow:hasTDP [
        exa-atow:hasValue 20670 ;
        exa-atow:hasUnit "W"
    ] ;
    exa-atow:belongsToPartition inst:Part_Adastra_GPU .


# ──── Adastra: APU (MI300A) node ──────────────────────────────────────────────
inst:Node_Adastra_APU rdf:type exa-atow:AcceleratedNode ;
    rdfs:label "Adastra2 – MI300A APU node type"@en ,
               "Adastra2 – Type nœud APU MI300A"@fr ;
    rdfs:comment "28 APU nodes (Adastra2). AMD MI300A: integrated CPU (24-core Zen4) + GPU (CDNA3) + 128 GB HBM3 unified memory. Very high energy efficiency."@en ,
                 "28 nœuds APU (Adastra2). AMD MI300A : CPU (24 cœurs Zen4) + GPU (CDNA3) + 128 Go HBM3 mémoire unifiée intégrés. Très haute efficacité énergétique."@fr ;
    exa-atow:cpuCorePerNode 96 ; # (4 * 24 @ 2.6 GHz)
    exa-atow:socketCount 0 ;    # APU: no separate CPU socket, CPU is part of the APU die
    exa-atow:ramPerNode 512 ;   # 4×128 GiB HBM3 (unified CPU+GPU memory)
    exa-atow:gpuCount 4 ;
    exa-atow:linkCount 4;
    exa-atow:connectedVia inst:IC_SlingShot_200G ;
    exa-atow:hasAcceleratorCard inst:Card_MI300A .

# ──── Adastra: visualization / prepost nodes ──────────────────────────────────
