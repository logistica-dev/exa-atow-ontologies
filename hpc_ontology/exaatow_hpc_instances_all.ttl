###############################################################################
# ══════════════════════════════════════════════════════════════════════════════
# SECTION 6 – COMPUTE NODES / NŒUDS DE CALCUL
# ══════════════════════════════════════════════════════════════════════════════
# EN – Node type descriptions. In a full deployment, each individual node
#      would be a separate instance; here we describe node TYPES (representative
#      instances) that can be referenced by partitions.
# FR – Description des types de nœuds. Dans un déploiement complet, chaque
#      nœud individuel serait une instance séparée ; ici on décrit les TYPES de
#      nœuds (instances représentatives) référencés par les partitions.
###############################################################################

# ──── Jean Zay: frontend nodes ────────────────────────────────────────────────
inst:Node_JZ_Frontend rdf:type exa-atow:FrontendNode ;
    rdfs:label "Jean Zay – Frontend node type"@en ,
               "Jean Zay – Type de nœud frontal"@fr ;
    rdfs:comment "5 frontend nodes on Jean Zay. Intel Xeon Gold 6248 (2×20 cores), 192 GB RAM, used for login, compilation and job submission."@en ,
                 "5 nœuds frontaux de Jean Zay. Intel Xeon Gold 6248 (2×20 cœurs), 192 Go RAM, utilisés pour la connexion, la compilation et la soumission de tâches."@fr ;
    exa-atow:socketCount 2 ;
    exa-atow:ramPerNode 192 ;
    exa-atow:connectedVia inst:IC_IntelOPA_100G ;
    exa-atow:equippedWith inst:CPU_IntelXeonGold6248 .

