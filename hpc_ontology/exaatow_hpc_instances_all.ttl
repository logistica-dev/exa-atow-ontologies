# ──── Jean Zay: cpu_p1 ────────────────────────────────────────────────────────
inst:Part_JZ_cpu_p1 rdf:type exa-atow:Partition ;
    rdfs:label "Jean Zay – cpu_p1 (default CPU partition)"@en ,
               "Jean Zay – cpu_p1 (partition CPU par défaut)"@fr ;
    rdfs:comment "Default CPU partition. 720 scalar nodes (40 cores/node, 192 GB RAM). Up to 100h walltime."@en ,
                 "Partition CPU par défaut. 720 nœuds scalaires (40 cœurs/nœud, 192 Go RAM). Jusqu'à 100h de temps mur."@fr ;
    exa-atow:partitionName "cpu_p1" ;
    exa-atow:nodeCount 720 ;
    exa-atow:maxWallTime "100:00:00" ;
    exa-atow:defaultWallTime "00:10:00" ;
    exa-atow:allocatedFromQuota true ;
    exa-atow:hasPartitionType exa-atow:CPUPartition ;
    exa-atow:usesNodeType inst:Node_JZ_cpu_p1 ;
    exa-atow:documentationURL "http://www.idris.fr/docs/jean-zay/jean-zay/jean-zay-hardware"^^xsd:anyURI .

